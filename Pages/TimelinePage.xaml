<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Cue.Pages.TimelinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Cue.ViewModels"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    FontFamily="{StaticResource CueFontFamily}"
    mc:Ignorable="d">

    <Page.Resources>
        <StaticResource x:Key="TimelineRowHoverBrush" ResourceKey="CueHoverFillBrush" />
        <SolidColorBrush x:Key="TimelineBarBrush" Color="{ThemeResource CardBackgroundFillColorDefault}" />

        <Style x:Key="TimelineMetadataTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CueFontSecondary}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <DataTemplate x:Key="TimelineDayTemplate" x:DataType="vm:TimelineDayViewModel">
            <Grid Width="{x:Bind Width}" Height="58">
                <Border BorderBrush="{ThemeResource DividerStrokeColorDefaultBrush}" BorderThickness="0,0,1,1" />
                <StackPanel VerticalAlignment="Center" Spacing="2">
                    <Border
                        MinWidth="28"
                        Height="28"
                        HorizontalAlignment="Center"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="14"
                        Visibility="{x:Bind IsToday, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource CueFontFamilySemiBold}"
                            FontSize="13"
                            Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                            Text="{x:Bind DayLabel}" />
                    </Border>
                    <TextBlock
                        HorizontalAlignment="Center"
                        FontFamily="{StaticResource CueFontFamilySemiBold}"
                        FontSize="13"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Text="{x:Bind DayLabel}"
                        Visibility="{x:Bind IsNotToday, Converter={StaticResource BoolToVisibility}}" />
                    <TextBlock
                        HorizontalAlignment="Center"
                        Style="{StaticResource TimelineMetadataTextStyle}"
                        Text="{x:Bind WeekdayLabel}" />
                </StackPanel>
            </Grid>
        </DataTemplate>

        <DataTemplate x:Key="TimelineRowTemplate" x:DataType="vm:TimelineTaskRowViewModel">
            <Grid Width="{x:Bind TrackWidth}" Height="70" Opacity="{x:Bind VisualOpacity}">
                <Rectangle
                    Height="1"
                    VerticalAlignment="Bottom"
                    Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                <Canvas Width="{x:Bind TrackWidth}" Height="70">
                    <Border
                        Canvas.Left="{x:Bind StartOffset}"
                        Canvas.Top="8"
                        Width="{x:Bind CardWidth}"
                        MinHeight="54"
                        Padding="12,0"
                        Background="{StaticResource TimelineBarBrush}"
                        BackgroundSizing="InnerBorderEdge"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource CueRadiusRow}"
                        PointerEntered="TimelineBar_PointerEntered"
                        PointerExited="TimelineBar_PointerExited"
                        Tapped="TimelineBar_Tapped"
                        Tag="{x:Bind Id}">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center" Spacing="1">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <Grid MaxWidth="142" VerticalAlignment="Center">
                                        <TextBlock
                                            x:Name="TimelineTitleText"
                                            FontSize="{StaticResource CueFontRow}"
                                            Loaded="FadeText_Loaded"
                                            MaxLines="1"
                                            SizeChanged="FadeText_SizeChanged"
                                            Text="{x:Bind Title}"
                                            TextTrimming="Clip" />
                                        <Rectangle
                                            x:Name="TimelineTitleFade"
                                            Width="48"
                                            HorizontalAlignment="Right"
                                            IsHitTestVisible="False"
                                            Opacity="0">
                                            <Rectangle.Fill>
                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                    <GradientStop Offset="0" Color="Transparent" />
                                                    <GradientStop Offset="0.58" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                                                    <GradientStop Offset="1" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                                                </LinearGradientBrush>
                                            </Rectangle.Fill>
                                        </Rectangle>
                                    </Grid>
                                    <Border
                                        Padding="7,1"
                                        VerticalAlignment="Center"
                                        Background="{x:Bind Priority, Converter={StaticResource PriorityToTint}}"
                                        CornerRadius="9"
                                        Visibility="{x:Bind HasPriority, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock
                                            FontSize="11"
                                            Foreground="{x:Bind Priority, Converter={StaticResource PriorityToBrush}}"
                                            Text="{x:Bind Priority, Converter={StaticResource PriorityToLabel}}" />
                                    </Border>
                                </StackPanel>
                                <TextBlock
                                    Style="{StaticResource TimelineMetadataTextStyle}"
                                    Text="{x:Bind DateCaption}"
                                    TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Canvas>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,10" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource CuePageTitleTextStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.RangeCaption, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="4">
                <Button
                    Width="34"
                    Height="34"
                    Padding="0"
                    Click="PreviousMonth_Click"
                    Style="{StaticResource CueSubtleTextButtonStyle}"
                    ToolTipService.ToolTip="이전 달"
                    AutomationProperties.Name="이전 달">
                    <FontIcon FontSize="14" Glyph="&#xE76B;" />
                </Button>
                <Button Click="Today_Click" Content="오늘" Style="{StaticResource CueSubtleTextButtonStyle}" />
                <Button
                    Width="34"
                    Height="34"
                    Padding="0"
                    Click="NextMonth_Click"
                    Style="{StaticResource CueSubtleTextButtonStyle}"
                    ToolTipService.ToolTip="다음 달"
                    AutomationProperties.Name="다음 달">
                    <FontIcon FontSize="14" Glyph="&#xE76C;" />
                </Button>
            </StackPanel>
        </Grid>

        <InfoBar x:Name="ErrorInfoBar" Grid.Row="1" Margin="4,0,4,8" IsClosable="True" IsOpen="False" Severity="Error" Title="타임라인을 표시하지 못했습니다" />

        <Grid
            x:Name="ContentSplitGrid"
            Grid.Row="2"
            ColumnSpacing="16"
            SizeChanged="ContentSplitGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Border
                Margin="4,0,4,4"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CueRadiusPanel}">
                <ScrollViewer
                    x:Name="TimelineScrollViewer"
                    HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    IsTabStop="True"
                    KeyDown="TimelineScrollViewer_KeyDown"
                    Loaded="TimelineScrollViewer_Loaded"
                    PointerCanceled="TimelineScrollViewer_PointerCanceled"
                    PointerMoved="TimelineScrollViewer_PointerMoved"
                    PointerPressed="TimelineScrollViewer_PointerPressed"
                    PointerReleased="TimelineScrollViewer_PointerReleased"
                    PointerWheelChanged="TimelineScrollViewer_PointerWheelChanged"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled"
                    ZoomMode="Disabled">
                        <Grid Width="{x:Bind ViewModel.TrackWidth, Mode=OneWay}" MinHeight="420">
                        <StackPanel>
                            <ItemsRepeater ItemTemplate="{StaticResource TimelineDayTemplate}" ItemsSource="{x:Bind ViewModel.Days, Mode=OneWay}">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" />
                                </ItemsRepeater.Layout>
                            </ItemsRepeater>
                            <ItemsRepeater
                                ItemTemplate="{StaticResource TimelineRowTemplate}"
                                ItemsSource="{x:Bind ViewModel.Rows, Mode=OneWay}"
                                ElementPrepared="TimelineRows_ElementPrepared"
                                ElementClearing="TimelineRows_ElementClearing" />
                        </StackPanel>
                        <Rectangle
                            Width="1"
                            HorizontalAlignment="Left"
                            Fill="{ThemeResource AccentFillColorDefaultBrush}"
                            IsHitTestVisible="False"
                            Opacity="0.8"
                            Visibility="{x:Bind ViewModel.HasTodayInRange, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <Rectangle.RenderTransform>
                                <TranslateTransform X="{x:Bind ViewModel.TodayLineOffset, Mode=OneWay}" />
                            </Rectangle.RenderTransform>
                        </Rectangle>
                    </Grid>
                </ScrollViewer>
            </Border>

            <TextBlock
                Margin="0,112,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="14"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="이 달에 표시할 날짜가 있는 할 일이 없습니다."
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

            <Border
                x:Name="DetailPanel"
                Grid.Column="1"
                Width="460"
                MinWidth="260"
                Margin="0,0,4,4"
                Padding="18,16,6,20"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CueRadiusPanel}"
                Loaded="DetailPanel_Loaded"
                SizeChanged="DetailPanel_SizeChanged"
                Visibility="{x:Bind ViewModel.Detail.IsOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Rectangle
                        Width="10"
                        Margin="-18,0,0,0"
                        HorizontalAlignment="Left"
                        Canvas.ZIndex="3"
                        Fill="Transparent"
                        PointerMoved="DetailResizeHandle_PointerMoved"
                        PointerEntered="DetailResizeHandle_PointerEntered"
                        PointerExited="DetailResizeHandle_PointerExited"
                        PointerPressed="DetailResizeHandle_PointerPressed"
                        PointerReleased="DetailResizeHandle_PointerReleased"
                        PointerCanceled="DetailResizeHandle_PointerReleased" />
                    <Border
                        x:Name="DetailResizeGrip"
                        Width="4"
                        Height="58"
                        Margin="-15,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Canvas.ZIndex="4"
                        Background="{ThemeResource TextFillColorTertiaryBrush}"
                        CornerRadius="2"
                        IsHitTestVisible="False"
                        Opacity="0">
                        <Border.OpacityTransition>
                            <ScalarTransition Duration="0:0:0.083" />
                        </Border.OpacityTransition>
                    </Border>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,0,16,0" Spacing="13">
                        <Grid ColumnSpacing="7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Padding="2,2,4,3"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="{StaticResource CueFontFamilySemiBold}"
                                FontSize="27"
                                LostFocus="DetailText_LostFocus"
                                PlaceholderText="할 일 제목"
                                Text="{x:Bind ViewModel.Detail.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                            <HyperlinkButton
                                Grid.Column="1"
                                Style="{StaticResource CueIconButtonStyle}"
                                Click="CloseDetail_Click"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                ToolTipService.ToolTip="닫기"
                                AutomationProperties.Name="닫기">
                                <FontIcon FontSize="17" Glyph="&#xE711;" />
                            </HyperlinkButton>
                        </Grid>

                        <Border Margin="4,2,8,7" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="11">
                                <TextBox AcceptsReturn="True" LostFocus="DetailText_LostFocus" MinHeight="92" PlaceholderText="메모를 추가하세요" Text="{x:Bind ViewModel.Detail.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                <Grid x:Name="DetailMetaGrid" ColumnSpacing="12" RowSpacing="10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="중요도" />
                                        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.Detail.Priorities}" SelectedItem="{x:Bind ViewModel.Detail.SelectedPriority, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource PriorityToLabel}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel x:Name="DetailGroupField" Grid.Column="1" Spacing="5"><TextBlock Text="그룹" /><ComboBox HorizontalAlignment="Stretch" DisplayMemberPath="Name" ItemsSource="{x:Bind ViewModel.Detail.TaskGroups}" SelectedItem="{x:Bind ViewModel.Detail.SelectedTaskGroup, Mode=TwoWay}" /></StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Margin="4,0,8,7" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="11">
                                <Button
                                    HorizontalAlignment="Left"
                                    Click="EnableWhen_Click"
                                    Content="+ 날짜 추가"
                                    Style="{StaticResource CueSubtleTextButtonStyle}"
                                    Visibility="{x:Bind ViewModel.Detail.CanAddWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                                <StackPanel Spacing="11" Visibility="{x:Bind ViewModel.Detail.IsWhenEditorVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <Grid>
                                        <TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="날짜" />
                                        <Button HorizontalAlignment="Right" Padding="8,3" Background="Transparent" BorderThickness="0" Click="ClearWhen_Click" Content="제거" />
                                    </Grid>
                                    <Grid x:Name="WhenDateTimeGrid" ColumnSpacing="8" RowSpacing="8" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CalendarDatePicker HorizontalAlignment="Stretch" Date="{x:Bind ViewModel.Detail.WhenDate, Mode=TwoWay}" PlaceholderText="날짜 선택" />
                                        <StackPanel
                                            x:Name="WhenTimePanel"
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="7"
                                            Visibility="{x:Bind ViewModel.Detail.ShowWhenTime, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                            <ComboBox Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Hours}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenHour, Mode=TwoWay}" />
                                            <TextBlock VerticalAlignment="Center" FontSize="18" Text=":" />
                                            <ComboBox Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Minutes}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenMinute, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Grid>
                                    <CheckBox Content="종일" IsChecked="{x:Bind ViewModel.Detail.IsWhenAllDay, Mode=TwoWay}" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="4,0,8,7" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="10">
                                <Grid><TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="태그" /><Button HorizontalAlignment="Right" Click="BeginAddTag_Click" Content="+ 새 태그" Style="{StaticResource CueSubtleTextButtonStyle}" /></Grid>
                                <!-- Inline new-tag field, shown in place of the old modal when + 새 태그 is tapped. -->
                                <Grid ColumnSpacing="8" Visibility="{x:Bind ViewModel.Detail.IsAddingTag, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="NewTagBox"
                                        KeyDown="NewTagBox_KeyDown"
                                        LostFocus="NewTagBox_LostFocus"
                                        PlaceholderText="태그 이름"
                                        Text="{x:Bind ViewModel.Detail.NewTagName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Click="ConfirmAddTag_Click" Content="추가" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Tags}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TagEditorOption">
                                            <Button
                                                Margin="0,1"
                                                Padding="8,7"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="TagRow_Click"
                                                CornerRadius="{StaticResource CueRadiusSmall}"
                                                Tag="{x:Bind Id}">
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon VerticalAlignment="Center" FontSize="15" Foreground="{x:Bind Color, Converter={StaticResource HexToBrush}}" Glyph="&#xE8EC;" />
                                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock x:Name="TagNameText" Loaded="FadeText_Loaded" SizeChanged="FadeText_SizeChanged" Text="{x:Bind Name}" TextTrimming="Clip" />
                                                        <Rectangle
                                                            x:Name="TagNameFade"
                                                            Width="24"
                                                            HorizontalAlignment="Right"
                                                            IsHitTestVisible="False"
                                                            Opacity="0">
                                                            <Rectangle.Fill>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Offset="0" Color="Transparent" />
                                                                    <GradientStop Offset="0.55" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                                                                    <GradientStop Offset="1" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                                                                </LinearGradientBrush>
                                                            </Rectangle.Fill>
                                                        </Rectangle>
                                                    </Grid>
                                                    <FontIcon Grid.Column="2" VerticalAlignment="Center" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Glyph="&#xE73E;" Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Margin="4,0,8,8" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="11">
                                <TextBlock Style="{StaticResource CueCardHeaderTextStyle}" Text="체크리스트" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox PlaceholderText="체크리스트 항목" Text="{x:Bind ViewModel.Detail.NewChecklistItemTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Click="AddChecklistItem_Click" Content="추가" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Checklist}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ChecklistItemViewModel">
                                            <Grid Margin="0,1" Padding="0,2" ColumnSpacing="10">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <CheckBox VerticalAlignment="Top" Margin="0,5,0,0" IsChecked="{x:Bind IsChecked, Mode=TwoWay}" Style="{StaticResource CueCircleCheckBoxStyle}" />
                                                <StackPanel Grid.Column="1" Spacing="3" Opacity="{x:Bind VisualOpacity, Mode=OneWay}">
                                                    <TextBox PlaceholderText="항목" Text="{x:Bind Title, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="6,4" FontSize="{StaticResource CueFontRowSub}" />
                                                    <TextBox PlaceholderText="메모" Text="{x:Bind Note, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" Padding="6,4" FontSize="{StaticResource CueFontRowSub}" />
                                                </StackPanel>
                                                <Button Grid.Column="2" VerticalAlignment="Top" Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="DeleteChecklistItem_Click" Tag="{x:Bind Id}" ToolTipService.ToolTip="삭제" AutomationProperties.Name="체크리스트 항목 삭제"><FontIcon FontSize="13" Glyph="&#xE74D;" /></Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Destructive action at the bottom, set apart by the critical color. -->
                        <Button
                            x:Name="DeleteTaskButton"
                            Margin="4,2,8,4"
                            Padding="10,9"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="Transparent"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Click="DeleteTask_Click"
                            CornerRadius="{StaticResource CueRadiusCard}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xE74D;" />
                                <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" Text="할 일 삭제" />
                            </StackPanel>
                        </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
