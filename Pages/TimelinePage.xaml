<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Cue.Pages.TimelinePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Cue.ViewModels"
    xmlns:behaviors="using:Cue.Behaviors"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    FontFamily="{StaticResource CueFontFamily}"
    mc:Ignorable="d">

    <Page.Resources>
        <StaticResource x:Key="TimelineRowHoverBrush" ResourceKey="CueHoverFillBrush" />
        <SolidColorBrush x:Key="TimelineBarBrush" Color="{ThemeResource CardBackgroundFillColorDefault}" />

        <Style x:Key="TimelineMetadataTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CueFontListMeta}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <!-- Tag chip — identical to the main list's (squircle tint pill). Duplicated here so the
             timeline card reads exactly like a list row. -->
        <DataTemplate x:Key="TimelineTagChipTemplate" x:DataType="vm:TaskRowTag">
            <Border
                Height="{StaticResource CueChipHeight}"
                Padding="{StaticResource CuePadChip}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Background="{x:Bind Color, Converter={StaticResource HexToTint}}"
                CornerRadius="{StaticResource CueRadiusChip}">
                <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap4}" VerticalAlignment="Center">
                    <FontIcon FontSize="12" Foreground="{x:Bind Color, Converter={StaticResource HexToBrush}}" Glyph="&#xE8EC;" />
                    <TextBlock MaxWidth="160" FontSize="{StaticResource CueFontListMeta}" Foreground="{x:Bind Color, Converter={StaticResource HexToBrush}}" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- A timeline task card: keeps the timeline's bordered-card feel, but its internals (checkbox,
             title + priority chip, time + repeat, group/tag chips) mirror the main list row exactly. The
             day section header carries the date, so the card shows only the time. -->
        <DataTemplate x:Key="TimelineCardTemplate" x:DataType="vm:TaskRowViewModel">
            <Border
                Background="{StaticResource TimelineBarBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CueRadiusRow}"
                Opacity="{x:Bind VisualOpacity, Mode=OneWay}"
                PointerEntered="TimelineBar_PointerEntered"
                PointerExited="TimelineBar_PointerExited"
                Tapped="TimelineBar_Tapped"
                Tag="{x:Bind Id}">
                <Border.BackgroundTransition>
                    <BrushTransition Duration="0:0:0.083" />
                </Border.BackgroundTransition>
                <Grid>
                    <!-- Persistent selected tint (open task), matching the list's selection fill. -->
                    <Rectangle
                        Fill="{StaticResource TimelineRowHoverBrush}"
                        RadiusX="8"
                        RadiusY="8"
                        Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                    <Grid MinHeight="56" Padding="14,10" ColumnSpacing="{StaticResource CueGap16}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <CheckBox
                            behaviors:CircleCheckBoxPop.IsEnabled="True"
                            VerticalAlignment="Center"
                            IsChecked="{x:Bind IsCompleted, Mode=TwoWay}"
                            Style="{StaticResource CueCircleCheckBoxStyle}" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="{StaticResource CueGap8}">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}">
                                <TextBlock
                                    MaxWidth="420"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource CueFontFamilySemiBold}"
                                    FontSize="{StaticResource CueFontListTitle}"
                                    Text="{x:Bind Title, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <Border
                                    Height="{StaticResource CueChipHeight}"
                                    Padding="{StaticResource CuePadChip}"
                                    VerticalAlignment="Center"
                                    Background="{x:Bind Priority, Converter={StaticResource PriorityToTint}, Mode=OneWay}"
                                    CornerRadius="{StaticResource CueRadiusChip}"
                                    Visibility="{x:Bind HasPriority, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{x:Bind Priority, Converter={StaticResource PriorityToBrush}, Mode=OneWay}" Text="{x:Bind Priority, Converter={StaticResource PriorityToLabel}, Mode=OneWay}" />
                                </Border>
                            </StackPanel>
                            <!-- Time + repeat line; shown when the task has a time or repeats. -->
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="{StaticResource CueGap8}"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind HasTimeOrRecurring, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource TimelineMetadataTextStyle}" Text="{x:Bind TimeCaption, Mode=OneWay}" Visibility="{x:Bind HasTimeCaption, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                <FontIcon
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xE8EE;"
                                    ToolTipService.ToolTip="반복"
                                    AutomationProperties.Name="반복"
                                    Visibility="{x:Bind IsRecurring, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                            <!-- Compact reflow: chips drop under the title when the card is narrow. -->
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}" Visibility="{x:Bind ShowInlineMeta, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <Border
                                    Height="{StaticResource CueChipHeight}"
                                    Padding="{StaticResource CuePadChip}"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource CueChipNeutralFillBrush}"
                                    CornerRadius="{StaticResource CueRadiusChip}"
                                    Visibility="{x:Bind HasGroup, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap4}" VerticalAlignment="Center">
                                        <FontIcon FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="{x:Bind GroupGlyph, Mode=OneWay}" />
                                        <TextBlock MaxWidth="160" FontSize="{StaticResource CueFontListMeta}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind GroupName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                                <ItemsControl ItemsSource="{x:Bind Tags, Mode=OneWay}" ItemTemplate="{StaticResource TimelineTagChipTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right edge (wide): group chip + tag chip(s), stacked and right-aligned. -->
                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Spacing="{StaticResource CueGap8}"
                            Visibility="{x:Bind ShowRightMeta, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <Border
                                Height="{StaticResource CueChipHeight}"
                                Padding="{StaticResource CuePadChip}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="{ThemeResource CueChipNeutralFillBrush}"
                                CornerRadius="{StaticResource CueRadiusChip}"
                                Visibility="{x:Bind HasGroup, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap4}" VerticalAlignment="Center">
                                    <FontIcon FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="{x:Bind GroupGlyph, Mode=OneWay}" />
                                    <TextBlock MaxWidth="160" FontSize="{StaticResource CueFontListMeta}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind GroupName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <ItemsControl HorizontalAlignment="Right" ItemsSource="{x:Bind Tags, Mode=OneWay}" ItemTemplate="{StaticResource TimelineTagChipTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Spacing="{StaticResource CueGap8}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>

        <!-- One day section: a date header (accent + 오늘 pill for today) over the day's task cards. -->
        <DataTemplate x:Key="TimelineDayTemplate" x:DataType="vm:TimelineDayViewModel">
            <StackPanel Margin="0,0,0,18" Loaded="DayRoot_Loaded">
                <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}" Margin="2,0,0,8" VerticalAlignment="Center">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource CueFontFamilySemiBold}"
                        FontSize="{StaticResource CueFontSection}"
                        Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                        Text="{x:Bind DateHeader}"
                        Visibility="{x:Bind IsToday, Converter={StaticResource BoolToVisibility}}" />
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource CueFontFamilySemiBold}"
                        FontSize="{StaticResource CueFontSection}"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                        Text="{x:Bind DateHeader}"
                        Visibility="{x:Bind IsNotToday, Converter={StaticResource BoolToVisibility}}" />
                    <Border
                        Height="{StaticResource CueChipHeight}"
                        Padding="{StaticResource CuePadChip}"
                        VerticalAlignment="Center"
                        Background="{ThemeResource AccentFillColorDefaultBrush}"
                        CornerRadius="{StaticResource CueRadiusChip}"
                        Visibility="{x:Bind IsToday, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock VerticalAlignment="Center" FontSize="{StaticResource CueFontListMeta}" Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}" Text="{x:Bind RelativeLabel}" />
                    </Border>
                    <TextBlock
                        VerticalAlignment="Center"
                        FontSize="{StaticResource CueFontListMeta}"
                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                        Text="{x:Bind RelativeLabel}"
                        Visibility="{x:Bind ShowSecondaryRelative, Converter={StaticResource BoolToVisibility}}" />
                </StackPanel>
                <ItemsRepeater ItemTemplate="{StaticResource TimelineCardTemplate}" ItemsSource="{x:Bind Tasks}">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Vertical" Spacing="{StaticResource CueGap8}" />
                    </ItemsRepeater.Layout>
                </ItemsRepeater>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="{StaticResource CuePadPage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,10" ColumnSpacing="{StaticResource CueGap12}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource CuePageTitleTextStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.RangeCaption, Mode=OneWay}" />
            </StackPanel>
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal" Spacing="{StaticResource CueGap4}">
                <Button
                    Width="34"
                    Height="34"
                    Padding="0"
                    Click="PreviousMonth_Click"
                    Style="{StaticResource CueSubtleTextButtonStyle}"
                    ToolTipService.ToolTip="이전 달"
                    AutomationProperties.Name="이전 달">
                    <FontIcon FontSize="14" Glyph="&#xE76B;" />
                </Button>
                <Button Click="Today_Click" Content="오늘" Style="{StaticResource CueSubtleTextButtonStyle}" />
                <Button
                    Width="34"
                    Height="34"
                    Padding="0"
                    Click="NextMonth_Click"
                    Style="{StaticResource CueSubtleTextButtonStyle}"
                    ToolTipService.ToolTip="다음 달"
                    AutomationProperties.Name="다음 달">
                    <FontIcon FontSize="14" Glyph="&#xE76C;" />
                </Button>
            </StackPanel>
        </Grid>

        <InfoBar x:Name="ErrorInfoBar" Grid.Row="1" Margin="4,0,4,8" IsClosable="True" IsOpen="False" Severity="Error" Title="타임라인을 표시하지 못했습니다" />

        <Grid
            x:Name="ContentSplitGrid"
            Grid.Row="2"
            ColumnSpacing="{StaticResource CueGap16}"
            SizeChanged="ContentSplitGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <!-- Timeline content (scrolling track + empty state). The code hides this while the detail
                 panel overlays it in the narrow layout, so the translucent panel keeps its exact color. -->
            <Grid x:Name="ContentContainer">
            <Border
                Margin="4,0,4,4"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CueRadiusPanel}">
                <ScrollViewer
                    x:Name="TimelineScrollViewer"
                    behaviors:ScrollBarAutoHide.IsEnabled="True"
                    HorizontalScrollMode="Disabled"
                    HorizontalScrollBarVisibility="Disabled"
                    IsTabStop="True"
                    Loaded="TimelineScrollViewer_Loaded"
                    VerticalScrollBarVisibility="Auto"
                    VerticalScrollMode="Enabled">
                    <ItemsRepeater
                        Margin="14,16,14,16"
                        ItemTemplate="{StaticResource TimelineDayTemplate}"
                        ItemsSource="{x:Bind ViewModel.Days, Mode=OneWay}"
                        ElementPrepared="TimelineRows_ElementPrepared"
                        ElementClearing="TimelineRows_ElementClearing">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" />
                        </ItemsRepeater.Layout>
                    </ItemsRepeater>
                </ScrollViewer>
            </Border>

            <TextBlock
                Margin="0,112,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="14"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="이 달에 표시할 날짜가 있는 할 일이 없습니다."
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </Grid>

            <Border
                x:Name="DetailPanel"
                Grid.Column="1"
                Width="460"
                MinWidth="260"
                Margin="0,0,4,4"
                Padding="{StaticResource CuePadDetailPanel}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CueRadiusPanel}"
                Loaded="DetailPanel_Loaded"
                SizeChanged="DetailPanel_SizeChanged"
                Visibility="{x:Bind ViewModel.Detail.IsOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Grid>
                    <Rectangle
                        x:Name="DetailResizeHitArea"
                        Width="10"
                        Margin="-18,0,0,0"
                        HorizontalAlignment="Left"
                        Canvas.ZIndex="3"
                        Fill="Transparent"
                        PointerMoved="DetailResizeHandle_PointerMoved"
                        PointerEntered="DetailResizeHandle_PointerEntered"
                        PointerExited="DetailResizeHandle_PointerExited"
                        PointerPressed="DetailResizeHandle_PointerPressed"
                        PointerReleased="DetailResizeHandle_PointerReleased"
                        PointerCanceled="DetailResizeHandle_PointerReleased" />
                    <Border
                        x:Name="DetailResizeGrip"
                        Width="4"
                        Height="58"
                        Margin="-15,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Canvas.ZIndex="4"
                        Background="{ThemeResource TextFillColorTertiaryBrush}"
                        CornerRadius="2"
                        IsHitTestVisible="False"
                        Opacity="0">
                        <Border.OpacityTransition>
                            <ScalarTransition Duration="0:0:0.083" />
                        </Border.OpacityTransition>
                    </Border>
                    <ScrollViewer behaviors:ScrollBarAutoHide.IsEnabled="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,0,4,0" Spacing="{StaticResource CueGap12}">
                        <Grid ColumnSpacing="{StaticResource CueGap8}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Padding="2,2,4,3"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="{StaticResource CueFontFamilySemiBold}"
                                FontSize="27"
                                KeyDown="DetailTitle_KeyDown"
                                LostFocus="DetailText_LostFocus"
                                PlaceholderText="할 일 제목"
                                Text="{x:Bind ViewModel.Detail.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap">
                                <!-- The title is a heading: keep it borderless in every state (suppress the
                                     accent focus border the other inputs get). It still saves on Enter / blur. -->
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                </TextBox.Resources>
                            </TextBox>
                            <HyperlinkButton
                                Grid.Column="1"
                                Style="{StaticResource CueIconButtonStyle}"
                                Click="CloseDetail_Click"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                ToolTipService.ToolTip="닫기"
                                AutomationProperties.Name="닫기">
                                <FontIcon FontSize="17" Glyph="&#xE711;" />
                            </HyperlinkButton>
                        </Grid>

                        <Border Margin="{StaticResource CuePadDetailCardFirst}" Padding="{StaticResource CuePadCard}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <TextBox AcceptsReturn="True" LostFocus="DetailText_LostFocus" MinHeight="92" PlaceholderText="메모를 추가하세요" Text="{x:Bind ViewModel.Detail.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                <Grid x:Name="DetailMetaGrid" ColumnSpacing="{StaticResource CueGap12}" RowSpacing="{StaticResource CueGap12}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Spacing="{StaticResource CueGap4}">
                                        <TextBlock Text="중요도" />
                                        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.Detail.Priorities}" SelectedItem="{x:Bind ViewModel.Detail.SelectedPriority, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource PriorityToLabel}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel x:Name="DetailGroupField" Grid.Column="1" Spacing="{StaticResource CueGap4}"><TextBlock Text="그룹" /><ComboBox HorizontalAlignment="Stretch" DisplayMemberPath="Name" ItemsSource="{x:Bind ViewModel.Detail.TaskGroups}" SelectedItem="{x:Bind ViewModel.Detail.SelectedTaskGroup, Mode=TwoWay}" /></StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Margin="{StaticResource CuePadDetailCard}" Padding="{StaticResource CuePadCard}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <Button
                                    HorizontalAlignment="Left"
                                    Click="EnableWhen_Click"
                                    Content="+ 날짜 추가"
                                    Style="{StaticResource CueSubtleTextButtonStyle}"
                                    Visibility="{x:Bind ViewModel.Detail.CanAddWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                                <StackPanel Spacing="{StaticResource CueGap12}" Visibility="{x:Bind ViewModel.Detail.IsWhenEditorVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <Grid>
                                        <TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="날짜" />
                                        <Button HorizontalAlignment="Right" Padding="8,3" Background="Transparent" BorderThickness="0" Click="ClearWhen_Click" Content="제거" />
                                    </Grid>
                                    <Grid x:Name="WhenDateTimeGrid" ColumnSpacing="{StaticResource CueGap8}" RowSpacing="{StaticResource CueGap8}" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CalendarDatePicker HorizontalAlignment="Stretch" Date="{x:Bind ViewModel.Detail.WhenDate, Mode=TwoWay}" PlaceholderText="날짜 선택" />
                                        <StackPanel
                                            x:Name="WhenTimePanel"
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="{StaticResource CueGap8}"
                                            Visibility="{x:Bind ViewModel.Detail.ShowWhenTime, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                            <ComboBox Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Hours}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenHour, Mode=TwoWay}" />
                                            <TextBlock VerticalAlignment="Center" FontSize="18" Text=":" />
                                            <ComboBox Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Minutes}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenMinute, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Grid>
                                    <CheckBox Content="종일" IsChecked="{x:Bind ViewModel.Detail.IsWhenAllDay, Mode=TwoWay}" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="{StaticResource CuePadDetailCard}" Padding="{StaticResource CuePadCard}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <Grid><TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="태그" /><Button HorizontalAlignment="Right" Click="BeginAddTag_Click" Content="+ 새 태그" Style="{StaticResource CueSubtleTextButtonStyle}" /></Grid>
                                <!-- Inline new-tag field, shown in place of the old modal when + 새 태그 is tapped. -->
                                <Grid ColumnSpacing="{StaticResource CueGap8}" Visibility="{x:Bind ViewModel.Detail.IsAddingTag, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="NewTagBox"
                                        KeyDown="NewTagBox_KeyDown"
                                        LostFocus="NewTagBox_LostFocus"
                                        PlaceholderText="태그 이름"
                                        Text="{x:Bind ViewModel.Detail.NewTagName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Click="ConfirmAddTag_Click" Content="추가" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Tags}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TagEditorOption">
                                            <Button
                                                Margin="0,1"
                                                Padding="8,7"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="TagRow_Click"
                                                CornerRadius="{StaticResource CueRadiusSmall}"
                                                Tag="{x:Bind Id}">
                                                <Grid ColumnSpacing="{StaticResource CueGap8}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon VerticalAlignment="Center" FontSize="15" Foreground="{x:Bind Color, Converter={StaticResource HexToBrush}}" Glyph="&#xE8EC;" />
                                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock x:Name="TagNameText" Loaded="FadeText_Loaded" SizeChanged="FadeText_SizeChanged" Text="{x:Bind Name}" TextTrimming="Clip" />
                                                        <Rectangle
                                                            x:Name="TagNameFade"
                                                            Width="24"
                                                            HorizontalAlignment="Right"
                                                            IsHitTestVisible="False"
                                                            Opacity="0">
                                                            <Rectangle.Fill>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Offset="0" Color="Transparent" />
                                                                    <GradientStop Offset="0.55" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                                                                    <GradientStop Offset="1" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                                                                </LinearGradientBrush>
                                                            </Rectangle.Fill>
                                                        </Rectangle>
                                                    </Grid>
                                                    <FontIcon Grid.Column="2" VerticalAlignment="Center" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Glyph="&#xE73E;" Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Margin="{StaticResource CuePadDetailCardLast}" Padding="{StaticResource CuePadCard}" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <TextBlock Style="{StaticResource CueCardHeaderTextStyle}" Text="체크리스트" />
                                <Grid ColumnSpacing="{StaticResource CueGap8}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox PlaceholderText="체크리스트 항목" Text="{x:Bind ViewModel.Detail.NewChecklistItemTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Click="AddChecklistItem_Click" Content="추가" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Checklist}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ChecklistItemViewModel">
                                            <Grid Margin="0,1" Padding="0,2" ColumnSpacing="{StaticResource CueGap8}">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="24" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <CheckBox Width="24" Height="24" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,5,0,0" behaviors:CircleCheckBoxPop.IsEnabled="True" IsChecked="{x:Bind IsChecked, Mode=TwoWay}" Style="{StaticResource CueCircleCheckBoxStyle}" />
                                                <TextBox Grid.Column="1" PlaceholderText="항목" KeyDown="ChecklistItemTitle_KeyDown" Text="{x:Bind Title, Mode=TwoWay}" Opacity="{x:Bind VisualOpacity, Mode=OneWay}" Background="Transparent" BorderBrush="Transparent" Padding="{StaticResource CuePadInput}" FontFamily="{StaticResource CueFontFamilyMedium}" FontSize="{StaticResource CueFontRowSub}" />
                                                <Button Grid.Column="2" VerticalAlignment="Top" Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="DeleteChecklistItem_Click" Tag="{x:Bind Id}" ToolTipService.ToolTip="삭제" AutomationProperties.Name="체크리스트 항목 삭제"><FontIcon FontSize="13" Glyph="&#xE74D;" /></Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Destructive action at the bottom, set apart by the critical color. -->
                        <Button
                            x:Name="DeleteTaskButton"
                            Margin="4,2,8,4"
                            Padding="10,9"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="Transparent"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Click="DeleteTask_Click"
                            CornerRadius="{StaticResource CueRadiusCard}">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}">
                                <FontIcon FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xE74D;" />
                                <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" Text="할 일 삭제" />
                            </StackPanel>
                        </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
