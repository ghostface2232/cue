<?xml version="1.0" encoding="utf-8"?>
<!-- ============================================================================================
     SPIKE — THROWAWAY CODE (Inline-highlight plan, Step 0: IME composition signal gate).
     Delete this file, ImeSpikePage.xaml.cs, the "imespike" NavigationViewItem in MainWindow.xaml,
     and the "imespike" branch in MainWindow.xaml.cs once Step 0 is decided. Do NOT build on this.
     ============================================================================================ -->
<Page
    x:Class="Cue.Pages.ImeSpikePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" RowSpacing="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Spacing="2">
            <TextBlock Text="IME 조합 신호 스파이크 (Step 0 — 버리는 코드)" FontSize="18" FontWeight="SemiBold" />
            <TextBlock TextWrapping="Wrap" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Text="한글 IME로 타이핑하며 아래 대시보드를 본다. 입력 예: '금요일 회의 내일 오후 3시' 후 Ctrl+Z 여러 번 / 'ㄱ→가→갈' 조합." />
        </StackPanel>

        <!-- The control under test. Metrics roughly mirror the real quick-add box. -->
        <Grid Grid.Row="1">
            <!-- Chip layer sits BEHIND the (transparent-background) editor, so chips show behind text. -->
            <Canvas x:Name="ChipLayer" IsHitTestVisible="False" />
            <RichEditBox
                x:Name="Box"
                MinHeight="48"
                Padding="14,12,14,10"
                CornerRadius="12"
                IsSpellCheckEnabled="False"
                FontSize="16"
                Background="Transparent" />
        </Grid>

        <!-- Experiment toggles. -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="20">
            <CheckBox x:Name="OverlayMode" Content="오버레이 칩 모드 (서식 대신 배경칩 · undo 무오염)" IsChecked="False" Checked="OverlayMode_Changed" Unchecked="OverlayMode_Changed" />
            <CheckBox x:Name="GateOnNonComposing" Content="비조합일 때만 재틴트 (끄면 leak 관찰)" IsChecked="True" />
            <CheckBox x:Name="IsolateUndoGroup" Content="틴트를 undo 그룹으로 묶기" IsChecked="True" />
            <Button x:Name="ClearLog" Content="카운터/로그 리셋" Click="ClearLog_Click" />
        </StackPanel>

        <!-- VERDICT row: color-coded "is this working?" at a glance. -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="10">
            <Border x:Name="VComposition" CornerRadius="6" Padding="10,6" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <TextBlock x:Name="VCompositionText" FontSize="13" Text="조합 신호 …" />
            </Border>
            <Border x:Name="VCaret" CornerRadius="6" Padding="10,6" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <TextBlock x:Name="VCaretText" FontSize="13" Text="caret …" />
            </Border>
            <Border x:Name="VUndo" CornerRadius="6" Padding="10,6" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <TextBlock x:Name="VUndoText" FontSize="13" Text="undo 단위 …" />
            </Border>
            <Border x:Name="VThrow" CornerRadius="6" Padding="10,6" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                <TextBlock x:Name="VThrowText" FontSize="13" Text="예외 0" />
            </Border>
        </StackPanel>

        <!-- Live state + counters (cheap to update, no scrolling). -->
        <Border Grid.Row="4" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="12,8">
            <StackPanel Spacing="4">
                <TextBlock x:Name="StateNow" FontFamily="Consolas" FontSize="13"
                           Text="IsComposing=false  caret=(0,0)  len=0  painted=0" />
                <TextBlock x:Name="StateCounters" FontFamily="Consolas" FontSize="13" Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                           Text="comp: start 0 / change 0 / end 0    tint: applied 0 / skipped 0    undo units 0    caret jumps 0" />
            </StackPanel>
        </Border>

        <!-- Recent NOTABLE events only (newest first, capped, no firehose). -->
        <Border Grid.Row="5" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                CornerRadius="8" Padding="12,8">
            <StackPanel>
                <TextBlock Text="최근 이벤트 (최신순, 조합 중간변화는 카운터로만 집계)" FontSize="12"
                           Foreground="{ThemeResource TextFillColorTertiaryBrush}" Margin="0,0,0,4" />
                <TextBlock x:Name="FeedText" FontFamily="Consolas" FontSize="12" IsTextSelectionEnabled="True"
                           TextWrapping="NoWrap" Text="" />
            </StackPanel>
        </Border>
    </Grid>
</Page>
