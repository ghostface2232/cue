<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Cue.Pages.TaskListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Cue.ViewModels"
    xmlns:behaviors="using:Cue.Behaviors"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    FontFamily="{StaticResource CueFontFamily}"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Theme-aware interactive brushes: Color comes from a ThemeResource so it flips light/dark
             (fixes the old hardcoded #0F000000 hover that was invisible in dark mode). -->
        <StaticResource x:Key="TaskHoverBrush" ResourceKey="CueHoverFillBrush" />
        <StaticResource x:Key="TaskPressedBrush" ResourceKey="CuePressedFillBrush" />
        <SolidColorBrush x:Key="DetailCardBrush" Color="{ThemeResource CardBackgroundFillColorDefault}" />

        <Style x:Key="MetadataTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CueFontListMeta}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <!-- A nested checklist item under a task: a checkbox and its (non-interactive) title only. It
             is not a task — it cannot be opened, dragged, or carry a date/priority/group. -->
        <DataTemplate x:Key="ChecklistRowTemplate" x:DataType="vm:ChecklistRowViewModel">
            <Border Margin="0,1,4,1" Padding="12,4" Opacity="{x:Bind VisualOpacity, Mode=OneWay}">
                <Grid ColumnSpacing="{StaticResource CueGap12}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <CheckBox
                        VerticalAlignment="Center"
                        IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                        Style="{StaticResource CueCircleCheckBoxStyle}" />
                    <TextBlock
                        Grid.Column="1"
                        MaxWidth="420"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource CueFontRowSub}"
                        Text="{x:Bind Title}"
                        TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TaskRowTemplate" x:DataType="vm:TaskRowViewModel">
            <StackPanel HorizontalAlignment="Stretch">
                <Border
                    Margin="4,1"
                    Padding="12,12"
                    Background="Transparent"
                    CornerRadius="{StaticResource CueRadiusRow}"
                    IsTabStop="True"
                    KeyDown="TaskSurface_KeyDown"
                    Loaded="TaskSurface_Loaded"
                    Opacity="{x:Bind VisualOpacity, Mode=OneWay}"
                    PointerEntered="TaskSurface_PointerEntered"
                    PointerExited="TaskSurface_PointerExited"
                    RightTapped="TaskSurface_RightTapped"
                    Tapped="TaskSurface_Tapped"
                    Tag="{x:Bind Id}">
                    <Border.BackgroundTransition>
                        <BrushTransition Duration="0:0:0.083" />
                    </Border.BackgroundTransition>
                    <Border.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </Border.Transitions>
                    <Grid ColumnSpacing="{StaticResource CueGap12}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Selected row gets a persistent fill (the hover tone) in addition to the accent
                             bar, so the open task reads as selected even while the pointer is elsewhere. -->
                        <Rectangle
                            Grid.ColumnSpan="4"
                            Margin="-12,-12"
                            Fill="{StaticResource TaskHoverBrush}"
                            RadiusX="8"
                            RadiusY="8"
                            Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                        <Rectangle
                            VerticalAlignment="Stretch"
                            Fill="{ThemeResource AccentFillColorDefaultBrush}"
                            RadiusX="1.5"
                            RadiusY="1.5"
                            Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                        <CheckBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{x:Bind IsCompleted, Mode=TwoWay}"
                            Style="{StaticResource CueCircleCheckBoxStyle}" />
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="{StaticResource CueGap4}">
                            <Grid ColumnSpacing="{StaticResource CueGap8}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock MaxWidth="520" VerticalAlignment="Center" FontSize="{StaticResource CueFontListTitle}" Text="{x:Bind Title, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                <Border
                                    Grid.Column="1"
                                    Padding="7,1"
                                    VerticalAlignment="Center"
                                    Background="{x:Bind Priority, Converter={StaticResource PriorityToTint}, Mode=OneWay}"
                                    CornerRadius="9"
                                    Visibility="{x:Bind HasPriority, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                                    <TextBlock FontSize="11" Foreground="{x:Bind Priority, Converter={StaticResource PriorityToBrush}, Mode=OneWay}" Text="{x:Bind Priority, Converter={StaticResource PriorityToLabel}, Mode=OneWay}" />
                                </Border>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap12}" Visibility="{x:Bind HasMetadata, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                                <TextBlock Style="{StaticResource MetadataTextStyle}" Text="{x:Bind Schedule, Mode=OneWay}" Visibility="{x:Bind HasSchedule, Converter={StaticResource BoolToVisibility}, Mode=OneWay}" />
                            </StackPanel>
                        </StackPanel>
                        <!-- Right edge: the task's group (icon + name) and tags (color dot + name).
                             Each chunk hides itself when the task has no group / no tags. -->
                        <StackPanel
                            Grid.Column="3"
                            Margin="12,0,2,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="{StaticResource CueGap12}">
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="{StaticResource CueGap4}"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind HasGroup, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <FontIcon FontSize="12" Foreground="{ThemeResource TextFillColorTertiaryBrush}" Glyph="{x:Bind GroupGlyph, Mode=OneWay}" />
                                <TextBlock FontSize="{StaticResource CueFontListMeta}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind GroupName, Mode=OneWay}" />
                            </StackPanel>
                            <ItemsControl ItemsSource="{x:Bind Tags, Mode=OneWay}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:TaskRowTag">
                                        <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap4}" VerticalAlignment="Center">
                                            <Ellipse Width="8" Height="8" VerticalAlignment="Center" Fill="{x:Bind Color, Converter={StaticResource HexToBrush}}" />
                                            <TextBlock FontSize="{StaticResource CueFontListMeta}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind Name}" />
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid Margin="31,0,0,7" Visibility="{x:Bind HasChecklist, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Margin="0,2,0,3" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <ItemsRepeater
                        Grid.Column="1"
                        Margin="6,0,0,0"
                        ElementClearing="TaskRepeater_ElementClearing"
                        ElementPrepared="TaskRepeater_ElementPrepared"
                        ItemTemplate="{StaticResource ChecklistRowTemplate}"
                        ItemsSource="{x:Bind ChecklistItems}" />
                </Grid>
                <!-- Thin separator between list rows for clear row-to-row division. -->
                <Rectangle Height="1" Margin="8,0" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="{StaticResource CuePadPage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,6" ColumnSpacing="{StaticResource CueGap12}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource CuePageTitleTextStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.TitleCaption, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasTitleCaption, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </Grid>

        <InfoBar x:Name="ErrorInfoBar" Grid.Row="1" Margin="4,0,4,8" IsClosable="True" IsOpen="False" Severity="Error" Title="작업을 완료하지 못했습니다" />

        <!-- Quick-add styled after the Files Omnibar: a floating pill with a CircleElevation border for
             subtle elevation (no drop shadow), centered text/icon, control-fill tone that lifts on
             hover and gains an accent ring on focus. -->
        <Grid Grid.Row="2" Margin="4,2,4,14">
            <TextBox
                MinHeight="48"
                Padding="46,13,14,9"
                VerticalContentAlignment="Center"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CircleElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="24"
                FontSize="15"
                IsEnabled="{x:Bind ViewModel.CanQuickAdd, Mode=OneWay}"
                KeyDown="QuickAdd_KeyDown"
                PlaceholderText="할 일을 입력하고 Enter — 예: 내일 오후 3시 회의 준비"
                Text="{x:Bind ViewModel.QuickAddText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Resources>
                    <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="ControlFillColorSecondaryBrush" />
                    <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="ControlFillColorDefaultBrush" />
                    <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="CircleElevationBorderBrush" />
                    <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="AccentFillColorDefaultBrush" />
                </TextBox.Resources>
            </TextBox>
            <FontIcon
                Margin="20,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="16"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Glyph="&#xE710;"
                IsHitTestVisible="False" />
        </Grid>

        <Grid
            x:Name="ContentSplitGrid"
            Grid.Row="3"
            ColumnSpacing="{StaticResource CueGap16}"
            SizeChanged="ContentSplitGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid>
                <ScrollViewer behaviors:ScrollBarAutoHide.IsEnabled="True" Visibility="{x:Bind ViewModel.IsStandardList, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <ItemsRepeater
                            ElementClearing="TaskRepeater_ElementClearing"
                            ElementPrepared="TaskRepeater_ElementPrepared"
                            ItemTemplate="{StaticResource TaskRowTemplate}"
                            ItemsSource="{x:Bind ViewModel.Tasks, Mode=OneWay}"
                            Loaded="ReorderRepeater_Loaded" />
                    </StackPanel>
                </ScrollViewer>

                <ListView
                    behaviors:ScrollBarAutoHide.IsEnabled="True"
                    ItemsSource="{x:Bind ViewModel.Groups, Mode=OneWay}"
                    SelectionMode="None"
                    Visibility="{x:Bind ViewModel.IsGroupedList, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskGroupViewModel">
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Margin="14,5,8,7" Style="{StaticResource CueSectionHeaderTextStyle}" Text="{x:Bind Name}" />
                                <ItemsRepeater ElementClearing="TaskRepeater_ElementClearing" ElementPrepared="TaskRepeater_ElementPrepared" ItemTemplate="{StaticResource TaskRowTemplate}" ItemsSource="{x:Bind Tasks}" Loaded="ReorderRepeater_Loaded" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock
                    Margin="0,96,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="표시할 할 일이 없습니다."
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </Grid>

            <Border
                x:Name="DetailPanel"
                Grid.Column="1"
                Width="460"
                MinWidth="260"
                Margin="0,0,4,4"
                Padding="{StaticResource CuePadDetailPanel}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CueRadiusPanel}"
                Loaded="DetailPanel_Loaded"
                SizeChanged="DetailPanel_SizeChanged"
                Visibility="{x:Bind ViewModel.Detail.IsOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Border.Resources>
                    <!-- Detail controls use the same hover/press fill as task rows so interaction
                         color stays consistent across light and dark surfaces. -->
                    <ResourceDictionary>
                        <ResourceDictionary.ThemeDictionaries>
                            <ResourceDictionary x:Key="Light">
                                <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                            </ResourceDictionary>
                            <ResourceDictionary x:Key="Dark">
                                <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                            </ResourceDictionary>
                        </ResourceDictionary.ThemeDictionaries>
                    </ResourceDictionary>
                </Border.Resources>
                <Grid>
                    <Rectangle
                        Width="10"
                        Margin="-18,0,0,0"
                        HorizontalAlignment="Left"
                        Canvas.ZIndex="3"
                        Fill="Transparent"
                        PointerMoved="DetailResizeHandle_PointerMoved"
                        PointerEntered="DetailResizeHandle_PointerEntered"
                        PointerExited="DetailResizeHandle_PointerExited"
                        PointerPressed="DetailResizeHandle_PointerPressed"
                        PointerReleased="DetailResizeHandle_PointerReleased"
                        PointerCanceled="DetailResizeHandle_PointerReleased" />
                    <Border
                        x:Name="DetailResizeGrip"
                        Width="4"
                        Height="58"
                        Margin="-15,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Canvas.ZIndex="4"
                        Background="{ThemeResource TextFillColorTertiaryBrush}"
                        CornerRadius="2"
                        IsHitTestVisible="False"
                        Opacity="0">
                        <Border.OpacityTransition>
                            <ScalarTransition Duration="0:0:0.083" />
                        </Border.OpacityTransition>
                    </Border>
                    <ScrollViewer behaviors:ScrollBarAutoHide.IsEnabled="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,0,4,0" Spacing="{StaticResource CueGap12}">
                        <Grid ColumnSpacing="{StaticResource CueGap8}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Padding="2,2,4,3"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="{StaticResource CueFontFamilySemiBold}"
                                FontSize="27"
                                LostFocus="DetailText_LostFocus"
                                PlaceholderText="할 일 제목"
                                Text="{x:Bind ViewModel.Detail.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                            <HyperlinkButton
                                Grid.Column="1"
                                Style="{StaticResource CueIconButtonStyle}"
                                Click="CloseDetail_Click"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                ToolTipService.ToolTip="닫기"
                                AutomationProperties.Name="닫기">
                                <FontIcon FontSize="17" Glyph="&#xE711;" />
                            </HyperlinkButton>
                        </Grid>

                        <Border Margin="{StaticResource CuePadDetailCardFirst}" Padding="{StaticResource CuePadCard}" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <TextBox AcceptsReturn="True" LostFocus="DetailText_LostFocus" MinHeight="92" PlaceholderText="메모를 추가하세요" Text="{x:Bind ViewModel.Detail.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                <Grid x:Name="DetailMetaGrid" ColumnSpacing="{StaticResource CueGap12}" RowSpacing="{StaticResource CueGap12}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Spacing="{StaticResource CueGap4}">
                                        <TextBlock Text="중요도" />
                                        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.Detail.Priorities}" SelectedItem="{x:Bind ViewModel.Detail.SelectedPriority, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource PriorityToLabel}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel x:Name="DetailGroupField" Grid.Column="1" Spacing="{StaticResource CueGap4}"><TextBlock Text="그룹" /><ComboBox HorizontalAlignment="Stretch" DisplayMemberPath="Name" ItemsSource="{x:Bind ViewModel.Detail.TaskGroups}" SelectedItem="{x:Bind ViewModel.Detail.SelectedTaskGroup, Mode=TwoWay}" /></StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- A task has a single date (When). Before a date is set the + 날짜 추가 button
                             takes the editor's place; once set, a date (+ optional time / 종일) shows. -->
                        <Border Margin="{StaticResource CuePadDetailCard}" Padding="{StaticResource CuePadCard}" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <Button
                                    HorizontalAlignment="Left"
                                    Click="EnableWhen_Click"
                                    Content="+ 일시 추가"
                                    Style="{StaticResource CueSubtleTextButtonStyle}"
                                    Visibility="{x:Bind ViewModel.Detail.CanAddWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                                <StackPanel Spacing="{StaticResource CueGap12}" Visibility="{x:Bind ViewModel.Detail.IsWhenEditorVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <Grid>
                                        <TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="일시" />
                                        <Button HorizontalAlignment="Right" Padding="8,3" Background="Transparent" BorderThickness="0" Click="ClearWhen_Click" Content="제거" />
                                    </Grid>
                                    <Grid x:Name="WhenDateTimeGrid" ColumnSpacing="{StaticResource CueGap8}" RowSpacing="{StaticResource CueGap8}" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CalendarDatePicker HorizontalAlignment="Stretch" Date="{x:Bind ViewModel.Detail.WhenDate, Mode=TwoWay}" PlaceholderText="날짜 선택" />
                                        <!-- Time picker. In the wide (2-column) layout the dropdowns sit at a
                                             fixed width beside the date; when the panel narrows to one column
                                             (see UpdateDetailResponsiveLayout) the columns go star and the
                                             dropdowns stretch to fill the card, matching the date picker. -->
                                        <Grid
                                            x:Name="WhenTimePanel"
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            ColumnSpacing="{StaticResource CueGap8}"
                                            Visibility="{x:Bind ViewModel.Detail.ShowWhenTime, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="WhenHourCol" Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition x:Name="WhenMinuteCol" Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="WhenHourCombo" Width="72" HorizontalAlignment="Stretch" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Hours}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenHour, Mode=TwoWay}" />
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="18" Text=":" />
                                            <ComboBox x:Name="WhenMinuteCombo" Grid.Column="2" Width="72" HorizontalAlignment="Stretch" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Minutes}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenMinute, Mode=TwoWay}" />
                                        </Grid>
                                    </Grid>
                                    <CheckBox Content="종일" IsChecked="{x:Bind ViewModel.Detail.IsWhenAllDay, Mode=TwoWay}" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="{StaticResource CuePadDetailCard}" Padding="{StaticResource CuePadCard}" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <Grid><TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="태그" /><Button HorizontalAlignment="Right" Click="BeginAddTag_Click" Content="+ 새 태그" Style="{StaticResource CueSubtleTextButtonStyle}" /></Grid>
                                <!-- Inline new-tag field, shown in place of the old modal when + 새 태그 is tapped. -->
                                <Grid ColumnSpacing="{StaticResource CueGap8}" Visibility="{x:Bind ViewModel.Detail.IsAddingTag, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="NewTagBox"
                                        KeyDown="NewTagBox_KeyDown"
                                        LostFocus="NewTagBox_LostFocus"
                                        PlaceholderText="태그 이름"
                                        Text="{x:Bind ViewModel.Detail.NewTagName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Click="ConfirmAddTag_Click" Content="추가" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Tags}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TagEditorOption">
                                            <Button
                                                Margin="0,1"
                                                Padding="8,7"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="TagRow_Click"
                                                CornerRadius="{StaticResource CueRadiusSmall}"
                                                Tag="{x:Bind Id}">
                                                <Grid ColumnSpacing="{StaticResource CueGap8}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon VerticalAlignment="Center" FontSize="15" Foreground="{x:Bind Color, Converter={StaticResource HexToBrush}}" Glyph="&#xE8EC;" />
                                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock x:Name="TagNameText" Loaded="FadeText_Loaded" SizeChanged="FadeText_SizeChanged" Text="{x:Bind Name}" TextTrimming="Clip" />
                                                        <Rectangle
                                                            x:Name="TagNameFade"
                                                            Width="24"
                                                            HorizontalAlignment="Right"
                                                            IsHitTestVisible="False"
                                                            Opacity="0">
                                                            <Rectangle.Fill>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Offset="0" Color="Transparent" />
                                                                    <GradientStop Offset="0.55" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                                                                    <GradientStop Offset="1" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                                                                </LinearGradientBrush>
                                                            </Rectangle.Fill>
                                                        </Rectangle>
                                                    </Grid>
                                                    <FontIcon Grid.Column="2" VerticalAlignment="Center" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Glyph="&#xE73E;" Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Margin="{StaticResource CuePadDetailCardLast}" Padding="{StaticResource CuePadCard}" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <TextBlock Style="{StaticResource CueCardHeaderTextStyle}" Text="체크리스트" />
                                <Grid ColumnSpacing="{StaticResource CueGap8}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox PlaceholderText="체크리스트 항목" Text="{x:Bind ViewModel.Detail.NewChecklistItemTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Click="AddChecklistItem_Click" Content="추가" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Checklist}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ChecklistItemViewModel">
                                            <Grid Margin="0,1" Padding="0,2" ColumnSpacing="{StaticResource CueGap12}">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <CheckBox VerticalAlignment="Top" Margin="0,5,0,0" IsChecked="{x:Bind IsChecked, Mode=TwoWay}" Style="{StaticResource CueCircleCheckBoxStyle}" />
                                                <StackPanel Grid.Column="1" Spacing="{StaticResource CueGap4}" Opacity="{x:Bind VisualOpacity, Mode=OneWay}">
                                                    <TextBox PlaceholderText="항목" Text="{x:Bind Title, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Padding="{StaticResource CuePadInput}" FontSize="{StaticResource CueFontRowSub}" />
                                                    <TextBox PlaceholderText="메모" Text="{x:Bind Note, Mode=TwoWay}" AcceptsReturn="True" TextWrapping="Wrap" Padding="{StaticResource CuePadInput}" FontSize="{StaticResource CueFontRowSub}" />
                                                </StackPanel>
                                                <Button Grid.Column="2" VerticalAlignment="Top" Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="DeleteChecklistItem_Click" Tag="{x:Bind Id}" ToolTipService.ToolTip="삭제" AutomationProperties.Name="체크리스트 항목 삭제"><FontIcon FontSize="13" Glyph="&#xE74D;" /></Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- Destructive action lives at the very bottom, set apart by its critical
                             color (DESIGN error token). Soft-delete via DeletedAt, with confirmation. -->
                        <Button
                            x:Name="DeleteTaskButton"
                            Margin="4,2,8,4"
                            Padding="10,9"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="Transparent"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Click="DeleteTask_Click"
                            CornerRadius="{StaticResource CueRadiusCard}">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}">
                                <FontIcon FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xE74D;" />
                                <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" Text="할 일 삭제" />
                            </StackPanel>
                        </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
