<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Cue.Pages.TaskListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Cue.ViewModels"
    xmlns:behaviors="using:Cue.Behaviors"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    FontFamily="{StaticResource CueFontFamily}"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Theme-aware interactive brushes: Color comes from a ThemeResource so it flips light/dark
             (fixes the old hardcoded #0F000000 hover that was invisible in dark mode). -->
        <StaticResource x:Key="TaskHoverBrush" ResourceKey="CueHoverFillBrush" />
        <StaticResource x:Key="TaskPressedBrush" ResourceKey="CuePressedFillBrush" />
        <SolidColorBrush x:Key="DetailCardBrush" Color="{ThemeResource CardBackgroundFillColorDefault}" />

        <Style x:Key="MetadataTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CueFontListMeta}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <!-- A tag chip on a task row: a soft pill tinted with the tag's own color, carrying a tag glyph
             + name in that saturated color. Shared by the wide (right-edge, stacked) and compact
             (under-title, inline) layouts; HorizontalAlignment=Right is a no-op in the horizontal
             compact panel and right-aligns the chip in the wide vertical stack. -->
        <DataTemplate x:Key="TagChipTemplate" x:DataType="vm:TaskRowTag">
            <Border
                Height="{StaticResource CueChipHeight}"
                Padding="{StaticResource CuePadChip}"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Background="{x:Bind Color, Converter={StaticResource HexToTint}}"
                CornerRadius="{StaticResource CueRadiusChip}">
                <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap4}" VerticalAlignment="Center">
                    <FontIcon FontSize="12" Foreground="{x:Bind Color, Converter={StaticResource HexToBrush}}" Glyph="&#xE8EC;" />
                    <TextBlock MaxWidth="160" FontSize="{StaticResource CueFontListMeta}" Foreground="{x:Bind Color, Converter={StaticResource HexToBrush}}" Text="{x:Bind Name}" TextTrimming="CharacterEllipsis" />
                </StackPanel>
            </Border>
        </DataTemplate>

        <!-- A nested checklist item under a task: a checkbox + title. It is not a task — it cannot be
             dragged or carry a date/priority/group; tapping the row (anywhere but the checkbox) opens
             its parent task's detail. -->
        <DataTemplate x:Key="ChecklistRowTemplate" x:DataType="vm:ChecklistRowViewModel">
            <Border Margin="0,1,4,1" Padding="12,4" Background="Transparent" Tag="{x:Bind ParentTaskId}" Tapped="ChecklistSurface_Tapped" Opacity="{x:Bind VisualOpacity, Mode=OneWay}">
                <Grid ColumnSpacing="{StaticResource CueGap12}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <CheckBox
                        Width="24"
                        Height="24"
                        behaviors:CircleCheckBoxPop.IsEnabled="True"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        IsChecked="{x:Bind IsChecked, Mode=TwoWay}"
                        Style="{StaticResource CueCircleCheckBoxStyle}" />
                    <TextBlock
                        Grid.Column="1"
                        MaxWidth="420"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        FontSize="{StaticResource CueFontRowSub}"
                        Text="{x:Bind Title}"
                        TextTrimming="CharacterEllipsis" />
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TaskRowTemplate" x:DataType="vm:TaskRowViewModel">
            <!-- The hover/selection surface wraps BOTH the task row and its nested checklist, so the
                 highlight (and the persistent selected fill) reads as one region covering the whole task.
                 No row separators: rows are divided by whitespace alone (more generous margins), not lines. -->
            <Border
                Margin="4,2"
                Background="Transparent"
                CornerRadius="{StaticResource CueRadiusRow}"
                IsTabStop="True"
                KeyDown="TaskSurface_KeyDown"
                Loaded="TaskSurface_Loaded"
                Opacity="{x:Bind VisualOpacity, Mode=OneWay}"
                PointerEntered="TaskSurface_PointerEntered"
                PointerExited="TaskSurface_PointerExited"
                RightTapped="TaskSurface_RightTapped"
                Tapped="TaskSurface_Tapped"
                Tag="{x:Bind Id}">
                <Border.BackgroundTransition>
                    <BrushTransition Duration="0:0:0.083" />
                </Border.BackgroundTransition>
                <Border.Transitions>
                    <TransitionCollection>
                        <RepositionThemeTransition />
                    </TransitionCollection>
                </Border.Transitions>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <!-- Selected task gets a persistent fill (the hover tone) spanning the row + checklist,
                         so the open task reads as selected even while the pointer is elsewhere. -->
                    <Rectangle
                        Grid.RowSpan="2"
                        Fill="{StaticResource TaskHoverBrush}"
                        RadiusX="8"
                        RadiusY="8"
                        Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                    <!-- Completion acknowledgement bar: takes the row's place for a beat after the task is
                         ticked. A one-off shows a filled check + "할 일을 완료했습니다" + an 실행 취소 (undo)
                         button; a repeating task shows a refresh glyph (spun one turn by the View) +
                         "이번 할 일을 완료했습니다" and no undo. The View folds the row away afterward. -->
                    <Grid
                        MinHeight="60"
                        Padding="16,12"
                        ColumnSpacing="{StaticResource CueGap16}"
                        Visibility="{x:Bind IsAcknowledging, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border
                            Width="20"
                            Height="20"
                            VerticalAlignment="Center"
                            Background="{ThemeResource AccentFillColorDefaultBrush}"
                            CornerRadius="10">
                            <Grid>
                                <FontIcon
                                    FontSize="12"
                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                    Glyph="&#xE73E;"
                                    Visibility="{x:Bind IsRecurringCompletion, Mode=OneWay, Converter={StaticResource InverseBoolToVisibility}}" />
                                <FontIcon
                                    x:Name="AckSpinIcon"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                    Glyph="&#xE72C;"
                                    RenderTransformOrigin="0.5,0.5"
                                    Visibility="{x:Bind IsRecurringCompletion, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                            </Grid>
                        </Border>
                        <TextBlock
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            FontFamily="{StaticResource CueFontFamilyMedium}"
                            FontSize="{StaticResource CueFontListTitle}"
                            Text="{x:Bind AcknowledgeMessage, Mode=OneWay}"
                            TextTrimming="CharacterEllipsis" />
                        <Button
                            Grid.Column="2"
                            Padding="10,6"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="UndoCompletion_Click"
                            Content="실행 취소"
                            Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}"
                            Visibility="{x:Bind ShowUndo, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>

                    <!-- Main row. Generous padding + a MinHeight so a bare title row keeps the same presence
                         as one with a schedule or chips; all content is vertically centered. -->
                    <Grid
                        MinHeight="60"
                        Padding="16,12"
                        ColumnSpacing="{StaticResource CueGap16}"
                        Visibility="{x:Bind ShowNormalContent, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <CheckBox
                            behaviors:CircleCheckBoxPop.IsEnabled="True"
                            VerticalAlignment="Center"
                            IsChecked="{x:Bind IsCompleted, Mode=TwoWay}"
                            Style="{StaticResource CueCircleCheckBoxStyle}" />

                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="{StaticResource CueGap4}">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}">
                                <TextBlock
                                    MaxWidth="520"
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource CueFontFamilySemiBold}"
                                    FontSize="{StaticResource CueFontListTitle}"
                                    Text="{x:Bind Title, Mode=OneWay}"
                                    TextTrimming="CharacterEllipsis" />
                                <Border
                                    Height="{StaticResource CueChipHeight}"
                                    Padding="{StaticResource CuePadChip}"
                                    VerticalAlignment="Center"
                                    Background="{x:Bind Priority, Converter={StaticResource PriorityToTint}, Mode=OneWay}"
                                    CornerRadius="{StaticResource CueRadiusChip}"
                                    Visibility="{x:Bind HasPriority, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                                    <TextBlock VerticalAlignment="Center" FontSize="12" Foreground="{x:Bind Priority, Converter={StaticResource PriorityToBrush}, Mode=OneWay}" Text="{x:Bind Priority, Converter={StaticResource PriorityToLabel}, Mode=OneWay}" />
                                </Border>
                            </StackPanel>
                            <!-- Schedule + recurrence line; hidden when the task carries no date. -->
                            <StackPanel
                                Orientation="Horizontal"
                                Spacing="{StaticResource CueGap8}"
                                VerticalAlignment="Center"
                                Visibility="{x:Bind HasSchedule, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                                <TextBlock VerticalAlignment="Center" Style="{StaticResource MetadataTextStyle}" Text="{x:Bind Schedule, Mode=OneWay}" />
                                <FontIcon
                                    VerticalAlignment="Center"
                                    FontSize="12"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    Glyph="&#xE8EE;"
                                    ToolTipService.ToolTip="반복"
                                    AutomationProperties.Name="반복"
                                    Visibility="{x:Bind IsRecurring, Converter={StaticResource BoolToVisibility}, Mode=OneWay}" />
                            </StackPanel>
                            <!-- Compact reflow: when the list is too narrow for right-edge chips, the same
                                 group/tag chips drop to their own line under the title (driven by IsCompact). -->
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}" Visibility="{x:Bind ShowInlineMeta, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <Border
                                    Height="{StaticResource CueChipHeight}"
                                    Padding="{StaticResource CuePadChip}"
                                    VerticalAlignment="Center"
                                    Background="{ThemeResource CueChipNeutralFillBrush}"
                                    CornerRadius="{StaticResource CueRadiusChip}"
                                    Visibility="{x:Bind HasGroup, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap4}" VerticalAlignment="Center">
                                        <FontIcon FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="{x:Bind GroupGlyph, Mode=OneWay}" />
                                        <TextBlock MaxWidth="160" FontSize="{StaticResource CueFontListMeta}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind GroupName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                    </StackPanel>
                                </Border>
                                <ItemsControl ItemsSource="{x:Bind Tags, Mode=OneWay}" ItemTemplate="{StaticResource TagChipTemplate}">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                </ItemsControl>
                            </StackPanel>
                        </StackPanel>

                        <!-- Right edge (wide layout): group chip + tag chip(s), stacked vertically and
                             right-aligned so their right edges line up. -->
                        <StackPanel
                            Grid.Column="2"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Spacing="{StaticResource CueGap8}"
                            Visibility="{x:Bind ShowRightMeta, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <Border
                                Height="{StaticResource CueChipHeight}"
                                Padding="{StaticResource CuePadChip}"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Background="{ThemeResource CueChipNeutralFillBrush}"
                                CornerRadius="{StaticResource CueRadiusChip}"
                                Visibility="{x:Bind HasGroup, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap4}" VerticalAlignment="Center">
                                    <FontIcon FontSize="12" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="{x:Bind GroupGlyph, Mode=OneWay}" />
                                    <TextBlock MaxWidth="160" FontSize="{StaticResource CueFontListMeta}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Text="{x:Bind GroupName, Mode=OneWay}" TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </Border>
                            <ItemsControl HorizontalAlignment="Right" ItemsSource="{x:Bind Tags, Mode=OneWay}" ItemTemplate="{StaticResource TagChipTemplate}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Vertical" HorizontalAlignment="Right" Spacing="{StaticResource CueGap8}" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                        </StackPanel>
                    </Grid>

                    <!-- Nested checklist (row 1 of the highlight grid), indented under the title. -->
                    <Grid Grid.Row="1" Margin="52,0,16,8" Visibility="{x:Bind ShowChecklist, Converter={StaticResource BoolToVisibility}, Mode=OneWay}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Rectangle Margin="0,2,0,3" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                        <ItemsRepeater
                            Grid.Column="1"
                            ElementClearing="TaskRepeater_ElementClearing"
                            ElementPrepared="TaskRepeater_ElementPrepared"
                            ItemTemplate="{StaticResource ChecklistRowTemplate}"
                            ItemsSource="{x:Bind ChecklistItems}" />
                    </Grid>
                </Grid>
            </Border>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="{StaticResource CuePadPage}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,6" ColumnSpacing="{StaticResource CueGap12}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource CuePageTitleTextStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.TitleCaption, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasTitleCaption, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
        </Grid>

        <InfoBar x:Name="ErrorInfoBar" Grid.Row="1" Margin="4,0,4,8" IsClosable="True" IsOpen="False" Severity="Error" Title="작업을 완료하지 못했습니다" />

        <!-- Quick-add styled after the Files Omnibar: a floating pill with a CircleElevation border for
             subtle elevation (no drop shadow), centered text/icon, control-fill tone that lifts on
             hover and gains an accent ring on focus. The whole pill is collapsed (not merely disabled)
             in views that can't quick-add — the 완료/중요도 screens — so a dead control never crowns the
             page and the header sits flush against the list. -->
        <Grid
            Grid.Row="2"
            Margin="4,2,4,14"
            Visibility="{x:Bind ViewModel.CanQuickAdd, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
            <TextBox
                MinHeight="48"
                Padding="46,13,14,9"
                VerticalContentAlignment="Center"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CircleElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="24"
                FontSize="15"
                KeyDown="QuickAdd_KeyDown"
                Text="{x:Bind ViewModel.QuickAddText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Resources>
                    <!-- Hover lift is theme-split. Light keeps the standard one-tone lift
                         (ControlFillColorSecondary). Dark's ControlFillColorSecondary (#15FFFFFF) jumps too
                         bright over the resting fill (#0FFFFFFF) on the dark page, so the dark hover uses a
                         gentler white overlay (#12FFFFFF) — a smaller, calmer lift. -->
                    <ResourceDictionary>
                        <ResourceDictionary.ThemeDictionaries>
                            <ResourceDictionary x:Key="Light">
                                <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="ControlFillColorSecondaryBrush" />
                                <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="ControlFillColorDefaultBrush" />
                                <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="CircleElevationBorderBrush" />
                                <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="AccentFillColorDefaultBrush" />
                            </ResourceDictionary>
                            <ResourceDictionary x:Key="Dark">
                                <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#12FFFFFF" />
                                <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="ControlFillColorDefaultBrush" />
                                <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="CircleElevationBorderBrush" />
                                <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="AccentFillColorDefaultBrush" />
                            </ResourceDictionary>
                        </ResourceDictionary.ThemeDictionaries>
                    </ResourceDictionary>
                </TextBox.Resources>
            </TextBox>
            <FontIcon
                Margin="20,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="16"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Glyph="&#xE710;"
                IsHitTestVisible="False" />
            <!-- Custom placeholder: PlaceholderText is a plain string, but a filtered view colors the
                 group/tag name with the accent, so the placeholder is two Runs in an overlay. Aligned to
                 the TextBox content (46px left padding; +2px down for its 13/9 top/bottom padding) and
                 shown only while the box is empty. -->
            <TextBlock
                Margin="46,4,14,0"
                VerticalAlignment="Center"
                FontSize="15"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                IsHitTestVisible="False"
                TextTrimming="CharacterEllipsis"
                Visibility="{x:Bind ViewModel.QuickAddIsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Run Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Text="{x:Bind ViewModel.QuickAddPlaceholderName, Mode=OneWay}" />
                <Run Text="{x:Bind ViewModel.QuickAddPlaceholderSuffix, Mode=OneWay}" />
            </TextBlock>
        </Grid>

        <Grid
            x:Name="ContentSplitGrid"
            Grid.Row="3"
            ColumnSpacing="{StaticResource CueGap16}"
            SizeChanged="ContentSplitGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid x:Name="ListContainer" SizeChanged="ListContainer_SizeChanged">
                <ScrollViewer behaviors:ScrollBarAutoHide.IsEnabled="True" Visibility="{x:Bind ViewModel.IsStandardList, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <ItemsRepeater
                            ElementClearing="TaskRepeater_ElementClearing"
                            ElementPrepared="TaskRepeater_ElementPrepared"
                            ItemTemplate="{StaticResource TaskRowTemplate}"
                            ItemsSource="{x:Bind ViewModel.Tasks, Mode=OneWay}"
                            Loaded="ReorderRepeater_Loaded" />

                        <!-- Collapsible "완료한 일" section (Today / group / tag). Hidden entirely when there
                             is nothing completed; starts collapsed. The header reuses the priority/sidebar
                             section look: title + count + chevron. The rows are completed (dimmed) and are
                             not drag-reorderable, so this repeater carries no reorder wiring. -->
                        <StackPanel
                            Margin="0,8,0,0"
                            Visibility="{x:Bind ViewModel.CompletedSection.HasItems, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <Button
                                Margin="0,5,8,2"
                                Padding="14,3,8,3"
                                HorizontalAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{x:Bind ViewModel.CompletedSection.ToggleExpandedCommand, Mode=OneWay}"
                                CornerRadius="{StaticResource CueRadiusRow}">
                                <Grid ColumnSpacing="{StaticResource CueGap8}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock VerticalAlignment="Center" Style="{StaticResource CuePriorityGroupHeaderTextStyle}" Text="{x:Bind ViewModel.CompletedSection.Title, Mode=OneWay}" />
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        FontSize="{StaticResource CueFontListMeta}"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Text="{x:Bind ViewModel.CompletedSection.Count.ToString(), Mode=OneWay}" />
                                    <FontIcon
                                        Grid.Column="2"
                                        HorizontalAlignment="Right"
                                        FontSize="12"
                                        Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                        Glyph="{x:Bind ViewModel.CompletedSection.IsExpanded, Mode=OneWay, Converter={StaticResource BoolToChevronGlyph}}" />
                                </Grid>
                            </Button>
                            <ItemsRepeater
                                ElementClearing="TaskRepeater_ElementClearing"
                                ElementPrepared="TaskRepeater_ElementPrepared"
                                ItemTemplate="{StaticResource TaskRowTemplate}"
                                ItemsSource="{x:Bind ViewModel.CompletedSection.Tasks, Mode=OneWay}"
                                Visibility="{x:Bind ViewModel.CompletedSection.IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                            <!-- "더 보기": completed rows page in (≈100 at a time), so a long history isn't
                                 realized all at once. Shown only while expanded with more rows left to load. -->
                            <Button
                                Margin="14,2,8,2"
                                Padding="14,4,14,4"
                                HorizontalAlignment="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{x:Bind ViewModel.CompletedSection.LoadMoreCommand, Mode=OneWay}"
                                CornerRadius="{StaticResource CueRadiusRow}"
                                Visibility="{x:Bind ViewModel.CompletedSection.CanLoadMore, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock
                                    FontSize="{StaticResource CueFontListMeta}"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    Text="더 보기" />
                            </Button>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ListView
                    behaviors:ScrollBarAutoHide.IsEnabled="True"
                    ItemsSource="{x:Bind ViewModel.PrioritySections, Mode=OneWay}"
                    SelectionMode="None"
                    Visibility="{x:Bind ViewModel.IsPrioritySectioned, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:PrioritySectionViewModel">
                            <StackPanel Margin="0,0,0,16">
                                <!-- Section header: tapping it collapses/expands the rows below. No add
                                     button (unlike the sidebar's group/tag sections) — just the name, the
                                     task count, and an expand/collapse chevron. -->
                                <Button
                                    Margin="0,5,8,2"
                                    Padding="14,3,8,3"
                                    HorizontalAlignment="Stretch"
                                    HorizontalContentAlignment="Stretch"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Command="{x:Bind ToggleExpandedCommand}"
                                    CornerRadius="{StaticResource CueRadiusRow}">
                                    <Grid ColumnSpacing="{StaticResource CueGap8}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock VerticalAlignment="Center" Style="{StaticResource CuePriorityGroupHeaderTextStyle}" Text="{x:Bind Name}" />
                                        <TextBlock
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            FontSize="{StaticResource CueFontListMeta}"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Text="{x:Bind Count.ToString(), Mode=OneWay}" />
                                        <FontIcon
                                            Grid.Column="2"
                                            HorizontalAlignment="Right"
                                            FontSize="12"
                                            Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                            Glyph="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToChevronGlyph}}" />
                                    </Grid>
                                </Button>
                                <ItemsRepeater
                                    ElementClearing="TaskRepeater_ElementClearing"
                                    ElementPrepared="TaskRepeater_ElementPrepared"
                                    ItemTemplate="{StaticResource TaskRowTemplate}"
                                    ItemsSource="{x:Bind Tasks}"
                                    Loaded="ReorderRepeater_Loaded"
                                    Visibility="{x:Bind IsExpanded, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <!-- 완료한 일 (Logbook): completed tasks grouped by day, newest first. Plain date headings
                     (오늘 / 어제 / a date), no collapse and no reorder — a flat history. -->
                <ListView
                    behaviors:ScrollBarAutoHide.IsEnabled="True"
                    ItemsSource="{x:Bind ViewModel.LogbookSections, Mode=OneWay}"
                    SelectionMode="None"
                    Visibility="{x:Bind ViewModel.IsLogbookSectioned, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:DateSectionViewModel">
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock
                                    Margin="14,8,8,4"
                                    Style="{StaticResource CuePriorityGroupHeaderTextStyle}"
                                    Text="{x:Bind DisplayTitle, Mode=OneWay}" />
                                <ItemsRepeater
                                    ElementClearing="TaskRepeater_ElementClearing"
                                    ElementPrepared="TaskRepeater_ElementPrepared"
                                    ItemTemplate="{StaticResource TaskRowTemplate}"
                                    ItemsSource="{x:Bind Tasks}" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock
                    Margin="0,96,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="표시할 할 일이 없습니다."
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </Grid>

            <Border
                x:Name="DetailPanel"
                Grid.Column="1"
                Width="460"
                MinWidth="260"
                Margin="0,0,4,4"
                Padding="{StaticResource CuePadDetailPanel}"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CueRadiusPanel}"
                Loaded="DetailPanel_Loaded"
                SizeChanged="DetailPanel_SizeChanged"
                Visibility="{x:Bind ViewModel.Detail.IsOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Border.Resources>
                    <!-- Detail controls use the same hover/press fill as task rows so interaction
                         color stays consistent across light and dark surfaces. -->
                    <ResourceDictionary>
                        <ResourceDictionary.ThemeDictionaries>
                            <ResourceDictionary x:Key="Light">
                                <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                            </ResourceDictionary>
                            <ResourceDictionary x:Key="Dark">
                                <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                            </ResourceDictionary>
                        </ResourceDictionary.ThemeDictionaries>
                    </ResourceDictionary>
                </Border.Resources>
                <Grid>
                    <Rectangle
                        x:Name="DetailResizeHitArea"
                        Width="24"
                        Margin="-18,0,0,0"
                        HorizontalAlignment="Left"
                        Canvas.ZIndex="3"
                        Fill="Transparent"
                        PointerMoved="DetailResizeHandle_PointerMoved"
                        PointerEntered="DetailResizeHandle_PointerEntered"
                        PointerExited="DetailResizeHandle_PointerExited"
                        PointerPressed="DetailResizeHandle_PointerPressed"
                        PointerReleased="DetailResizeHandle_PointerReleased"
                        PointerCanceled="DetailResizeHandle_PointerReleased" />
                    <Border
                        x:Name="DetailResizeGrip"
                        Width="4"
                        Height="58"
                        Margin="-15,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Canvas.ZIndex="4"
                        Background="{ThemeResource TextFillColorTertiaryBrush}"
                        CornerRadius="2"
                        IsHitTestVisible="False"
                        Opacity="0">
                        <Border.OpacityTransition>
                            <ScalarTransition Duration="0:0:0.083" />
                        </Border.OpacityTransition>
                    </Border>
                    <ScrollViewer behaviors:ScrollBarAutoHide.IsEnabled="True" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,0,4,0" Spacing="{StaticResource CueGap12}">
                        <Grid ColumnSpacing="{StaticResource CueGap8}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Padding="2,2,4,3"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="{StaticResource CueFontFamilySemiBold}"
                                FontSize="24"
                                KeyDown="DetailTitle_KeyDown"
                                LostFocus="DetailText_LostFocus"
                                PlaceholderText="할 일 제목"
                                Text="{x:Bind ViewModel.Detail.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap">
                                <!-- The title is a heading: keep it borderless in every state (suppress the
                                     accent focus border the other inputs get). It still saves on Enter / blur. -->
                                <TextBox.Resources>
                                    <SolidColorBrush x:Key="TextControlBorderBrushFocused" Color="Transparent" />
                                </TextBox.Resources>
                            </TextBox>
                            <HyperlinkButton
                                Grid.Column="1"
                                Style="{StaticResource CueIconButtonStyle}"
                                Click="CloseDetail_Click"
                                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                ToolTipService.ToolTip="닫기"
                                AutomationProperties.Name="닫기">
                                <FontIcon FontSize="17" Glyph="&#xE711;" />
                            </HyperlinkButton>
                        </Grid>

                        <Border Margin="{StaticResource CuePadDetailCardFirst}" Padding="{StaticResource CuePadCard}" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <TextBox AcceptsReturn="True" LostFocus="DetailText_LostFocus" MinHeight="92" PlaceholderText="메모를 추가하세요" Text="{x:Bind ViewModel.Detail.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                <Grid x:Name="DetailMetaGrid" ColumnSpacing="{StaticResource CueGap12}" RowSpacing="{StaticResource CueGap12}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Spacing="{StaticResource CueGap4}">
                                        <TextBlock Text="중요도" />
                                        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.Detail.Priorities}" SelectedItem="{x:Bind ViewModel.Detail.SelectedPriority, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource PriorityToLabel}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel x:Name="DetailGroupField" Grid.Column="1" Spacing="{StaticResource CueGap4}"><TextBlock Text="그룹" /><ComboBox HorizontalAlignment="Stretch" DisplayMemberPath="Name" ItemsSource="{x:Bind ViewModel.Detail.TaskGroups}" SelectedItem="{x:Bind ViewModel.Detail.SelectedTaskGroup, Mode=TwoWay}" /></StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- A task has a single date (When). Before a date is set the + 날짜 추가 button
                             takes the editor's place; once set, a date (+ optional time / 종일) shows. -->
                        <Border Margin="{StaticResource CuePadDetailCard}" Padding="{StaticResource CuePadCard}" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <Button
                                    HorizontalAlignment="Left"
                                    Click="EnableWhen_Click"
                                    Content="+ 일시 추가"
                                    Style="{StaticResource CueSubtleTextButtonStyle}"
                                    Visibility="{x:Bind ViewModel.Detail.CanAddWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                                <StackPanel Spacing="{StaticResource CueGap12}" Visibility="{x:Bind ViewModel.Detail.IsWhenEditorVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <Grid>
                                        <TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="일시" />
                                        <Button HorizontalAlignment="Right" Padding="8,3" Background="Transparent" BorderThickness="0" Click="ClearWhen_Click" Content="제거" />
                                    </Grid>
                                    <Grid x:Name="WhenDateTimeGrid" ColumnSpacing="{StaticResource CueGap8}" RowSpacing="{StaticResource CueGap8}" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CalendarDatePicker HorizontalAlignment="Stretch" Date="{x:Bind ViewModel.Detail.WhenDate, Mode=TwoWay}" PlaceholderText="날짜 선택" />
                                        <!-- Time picker. In the wide (2-column) layout the dropdowns sit at a
                                             fixed width beside the date; when the panel narrows to one column
                                             (see UpdateDetailResponsiveLayout) the columns go star and the
                                             dropdowns stretch to fill the card, matching the date picker. -->
                                        <Grid
                                            x:Name="WhenTimePanel"
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            ColumnSpacing="{StaticResource CueGap8}"
                                            Visibility="{x:Bind ViewModel.Detail.ShowWhenTime, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition x:Name="WhenHourCol" Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition x:Name="WhenMinuteCol" Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <ComboBox x:Name="WhenHourCombo" Width="72" HorizontalAlignment="Stretch" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Hours}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenHour, Mode=TwoWay}" />
                                            <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="18" Text=":" />
                                            <ComboBox x:Name="WhenMinuteCombo" Grid.Column="2" Width="72" HorizontalAlignment="Stretch" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Minutes}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenMinute, Mode=TwoWay}" />
                                        </Grid>
                                    </Grid>
                                    <CheckBox Content="종일" IsChecked="{x:Bind ViewModel.Detail.IsWhenAllDay, Mode=TwoWay}" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                </StackPanel>

                                <!-- 반복 (recurrence) field. Shown only when the task carries a concrete 일시 —
                                     a recurrence with no date to anchor it doesn't read as meaningful, so
                                     removing the date removes this field too (and clears the rule, see
                                     ClearWhen). A plain field label (like 중요도 / 그룹), not a card header, so
                                     it doesn't read as a second card title. The picker offers common presets;
                                     a parsed rule with no preset shows as its own summarized entry so it
                                     round-trips. -->
                                <StackPanel
                                    Spacing="{StaticResource CueGap4}"
                                    Visibility="{x:Bind ViewModel.Detail.IsWhenEditorVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="반복" />
                                    <ComboBox
                                        HorizontalAlignment="Stretch"
                                        DisplayMemberPath="Name"
                                        ItemsSource="{x:Bind ViewModel.Detail.RecurrenceOptions}"
                                        SelectedItem="{x:Bind ViewModel.Detail.SelectedRecurrence, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- 기록 (recurrence cycle timeline). Shown only for a recurring task. A compact,
                             fixed-height horizontal agenda strip of cycle pips — not a large card carousel —
                             so a long history never grows the panel vertically. The most recent cycles and
                             the live head pip (다음 / 종료) read by default; ‹ pages older cycles in on
                             demand (never eager-loading all), › scrolls back toward the head. Each pip carries
                             a glyph + date + status word + tooltip + automation name, so status never depends
                             on color; tapping a recorded pip opens a flyout with its time + checklist snapshot
                             and lets its status be corrected. -->
                        <Border
                            Margin="{StaticResource CuePadDetailCard}"
                            Padding="{StaticResource CuePadCard}"
                            Background="{StaticResource DetailCardBrush}"
                            CornerRadius="{StaticResource CueRadiusCard}"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            BackgroundSizing="InnerBorderEdge"
                            Visibility="{x:Bind ViewModel.Detail.IsRecurring, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Spacing="{StaticResource CueGap8}">
                                <TextBlock Style="{StaticResource CueCardHeaderTextStyle}" Text="기록" />
                                <Grid ColumnSpacing="{StaticResource CueGap4}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button
                                        x:Name="TimelinePrevButton"
                                        Width="28"
                                        Height="{StaticResource CueTimelineStripHeight}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="TimelinePrev_Click"
                                        AutomationProperties.Name="이전 기록"
                                        ToolTipService.ToolTip="이전 기록">
                                        <FontIcon FontSize="13" Glyph="&#xE76B;" />
                                    </Button>
                                    <ScrollViewer
                                        x:Name="TimelineScroller"
                                        Grid.Column="1"
                                        Height="{StaticResource CueTimelineStripHeight}"
                                        HorizontalScrollMode="Auto"
                                        HorizontalScrollBarVisibility="Hidden"
                                        VerticalScrollMode="Disabled"
                                        VerticalScrollBarVisibility="Disabled">
                                        <ItemsRepeater ItemsSource="{x:Bind ViewModel.Detail.Timeline, Mode=OneWay}" SizeChanged="TimelineRepeater_SizeChanged">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Orientation="Horizontal" Spacing="{StaticResource CueGap4}" />
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="vm:OccurrencePipViewModel">
                                                    <!-- Each pip reads like a day cell from the old horizontal timeline's header:
                                                         the date sits up top (SemiBold) over a status glyph + word, with the live
                                                         head pip (다음 / 종료) wrapping its date in an accent pill — the same accent
                                                         "today" marker that header used. Only that day-strip content layout is
                                                         borrowed; the pips stay flat (no card surface) so the 기록 strip keeps the
                                                         same chrome as the other detail tabs. -->
                                                    <Button
                                                        Width="{StaticResource CueTimelinePipWidth}"
                                                        Height="{StaticResource CueTimelineStripHeight}"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        CornerRadius="{StaticResource CueRadiusSmall}"
                                                        Click="OccurrencePip_Click"
                                                        AutomationProperties.Name="{x:Bind AutomationName, Mode=OneWay}"
                                                        ToolTipService.ToolTip="{x:Bind Tooltip, Mode=OneWay}">
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="2">
                                                            <!-- Date slot — one fixed-height row shared by every pip so the glyph and
                                                                 status below line up across recorded and head pips. Both date variants
                                                                 are centered in this same slot, so only the emphasis differs (the head
                                                                 pip's accent pill — the old timeline's "today" disc), never the position. -->
                                                            <Grid Height="22">
                                                                <Border
                                                                    Height="22"
                                                                    MinWidth="34"
                                                                    Padding="8,0"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                                    CornerRadius="11"
                                                                    Visibility="{x:Bind IsHead, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                                                    <TextBlock
                                                                        HorizontalAlignment="Center"
                                                                        VerticalAlignment="Center"
                                                                        TextLineBounds="Tight"
                                                                        FontFamily="{StaticResource CueFontFamilySemiBold}"
                                                                        FontSize="{StaticResource CueFontListMeta}"
                                                                        Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                                                        Text="{x:Bind DateLabel}" />
                                                                </Border>
                                                                <TextBlock
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    TextLineBounds="Tight"
                                                                    FontFamily="{StaticResource CueFontFamilySemiBold}"
                                                                    FontSize="{StaticResource CueFontListMeta}"
                                                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                                    Text="{x:Bind DateLabel}"
                                                                    Visibility="{x:Bind IsNotHead, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                                            </Grid>
                                                            <TextBlock
                                                                Height="20"
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"
                                                                TextAlignment="Center"
                                                                TextLineBounds="Tight"
                                                                FontSize="{StaticResource CueTimelinePipGlyph}"
                                                                Foreground="{x:Bind Kind, Mode=OneWay, Converter={StaticResource OccurrencePipKindToBrush}}"
                                                                Text="{x:Bind Glyph, Mode=OneWay}" />
                                                            <TextBlock
                                                                HorizontalAlignment="Center"
                                                                TextAlignment="Center"
                                                                FontSize="{StaticResource CueFontSecondary}"
                                                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                                                Text="{x:Bind StatusLabel, Mode=OneWay}" />
                                                        </StackPanel>
                                                    </Button>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </ScrollViewer>
                                    <Button
                                        Grid.Column="2"
                                        Width="28"
                                        Height="{StaticResource CueTimelineStripHeight}"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="TimelineNext_Click"
                                        AutomationProperties.Name="다음 기록"
                                        ToolTipService.ToolTip="다음 기록">
                                        <FontIcon FontSize="13" Glyph="&#xE76C;" />
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Margin="{StaticResource CuePadDetailCard}" Padding="{StaticResource CuePadCard}" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <Grid><TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="태그" /><Button HorizontalAlignment="Right" Click="BeginAddTag_Click" Content="+ 새 태그" Style="{StaticResource CueSubtleTextButtonStyle}" /></Grid>
                                <!-- Inline new-tag field, shown in place of the old modal when + 새 태그 is tapped. -->
                                <Grid ColumnSpacing="{StaticResource CueGap8}" Visibility="{x:Bind ViewModel.Detail.IsAddingTag, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="NewTagBox"
                                        KeyDown="NewTagBox_KeyDown"
                                        LostFocus="NewTagBox_LostFocus"
                                        PlaceholderText="태그 이름"
                                        Text="{x:Bind ViewModel.Detail.NewTagName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Click="ConfirmAddTag_Click" Content="추가" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Tags}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:TagEditorOption">
                                            <Button
                                                Margin="0,1"
                                                Padding="8,7"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="TagRow_Click"
                                                CornerRadius="{StaticResource CueRadiusSmall}"
                                                Tag="{x:Bind Id}">
                                                <Grid ColumnSpacing="{StaticResource CueGap8}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon VerticalAlignment="Center" FontSize="15" Foreground="{x:Bind Color, Converter={StaticResource HexToBrush}}" Glyph="&#xE8EC;" />
                                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock x:Name="TagNameText" Loaded="FadeText_Loaded" SizeChanged="FadeText_SizeChanged" Text="{x:Bind Name}" TextTrimming="Clip" />
                                                        <Rectangle
                                                            x:Name="TagNameFade"
                                                            Width="24"
                                                            HorizontalAlignment="Right"
                                                            IsHitTestVisible="False"
                                                            Opacity="0">
                                                            <Rectangle.Fill>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Offset="0" Color="Transparent" />
                                                                    <GradientStop Offset="0.55" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                                                                    <GradientStop Offset="1" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                                                                </LinearGradientBrush>
                                                            </Rectangle.Fill>
                                                        </Rectangle>
                                                    </Grid>
                                                    <FontIcon Grid.Column="2" VerticalAlignment="Center" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Glyph="&#xE73E;" Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Margin="{StaticResource CuePadDetailCardLast}" Padding="{StaticResource CuePadCard}" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="{StaticResource CueGap12}">
                                <TextBlock Style="{StaticResource CueCardHeaderTextStyle}" Text="체크리스트" />
                                <Grid ColumnSpacing="{StaticResource CueGap8}">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox PlaceholderText="체크리스트 항목" Text="{x:Bind ViewModel.Detail.NewChecklistItemTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Click="AddChecklistItem_Click" Content="추가" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Checklist}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:ChecklistItemViewModel">
                                            <Grid Margin="0,1" Padding="0,2" ColumnSpacing="{StaticResource CueGap8}">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="24" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <CheckBox Width="24" Height="24" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="0,5,0,0" behaviors:CircleCheckBoxPop.IsEnabled="True" IsChecked="{x:Bind IsChecked, Mode=TwoWay}" Style="{StaticResource CueCircleCheckBoxStyle}" />
                                                <TextBox Grid.Column="1" PlaceholderText="항목" KeyDown="ChecklistItemTitle_KeyDown" Text="{x:Bind Title, Mode=TwoWay}" Opacity="{x:Bind VisualOpacity, Mode=OneWay}" Background="Transparent" BorderBrush="Transparent" Padding="{StaticResource CuePadInput}" FontFamily="{StaticResource CueFontFamilyMedium}" FontSize="{StaticResource CueFontRowSub}" />
                                                <Button Grid.Column="2" VerticalAlignment="Top" Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="DeleteChecklistItem_Click" Tag="{x:Bind Id}" ToolTipService.ToolTip="삭제" AutomationProperties.Name="체크리스트 항목 삭제"><FontIcon FontSize="13" Glyph="&#xE74D;" /></Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <!-- 반복 종료 (end the series). Explicit action in place of any hidden gesture, shown
                             only for a recurring task. "완료" is intentionally avoided here — that word means
                             the current cycle; ending the series moves the whole task to 완료한 일. -->
                        <Button
                            x:Name="EndSeriesButton"
                            Margin="4,2,8,4"
                            Padding="10,9"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="Transparent"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Click="EndSeries_Click"
                            CornerRadius="{StaticResource CueRadiusCard}"
                            Visibility="{x:Bind ViewModel.Detail.IsRecurring, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}">
                                <FontIcon FontSize="14" Glyph="&#xE7C1;" />
                                <TextBlock Text="반복 종료" />
                            </StackPanel>
                        </Button>

                        <!-- Destructive action lives at the very bottom, set apart by its critical
                             color (DESIGN error token). Soft-delete via DeletedAt, with confirmation. -->
                        <Button
                            x:Name="DeleteTaskButton"
                            Margin="4,2,8,4"
                            Padding="10,9"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Center"
                            Background="Transparent"
                            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1"
                            Click="DeleteTask_Click"
                            CornerRadius="{StaticResource CueRadiusCard}">
                            <StackPanel Orientation="Horizontal" Spacing="{StaticResource CueGap8}">
                                <FontIcon FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}" Glyph="&#xE74D;" />
                                <TextBlock Foreground="{ThemeResource SystemFillColorCriticalBrush}" Text="할 일 삭제" />
                            </StackPanel>
                        </Button>
                        </StackPanel>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
