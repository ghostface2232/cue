<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Cue.Pages.TaskListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Cue.ViewModels"
    mc:Ignorable="d">

    <Page.Resources>
        <DataTemplate x:Key="TaskRowTemplate" x:DataType="vm:TaskRowViewModel">
            <Grid ColumnSpacing="12" Padding="0,6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <CheckBox
                    MinWidth="0"
                    VerticalAlignment="Top"
                    IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind Title}" TextWrapping="Wrap" />
                    <TextBlock
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                        Style="{StaticResource CaptionTextBlockStyle}"
                        Text="{x:Bind Schedule}"
                        Visibility="{x:Bind ScheduleVisibility}" />
                </StackPanel>
            </Grid>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="24,16,24,16" RowSpacing="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource TitleTextBlockStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.TitleCaption, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasTitleCaption, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
            <Button
                Grid.Column="1"
                Click="AddSection_Click"
                Content="섹션 추가"
                Visibility="{x:Bind ViewModel.IsProjectMode, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
        </Grid>

        <TextBox
            Grid.Row="1"
            KeyDown="QuickAdd_KeyDown"
            PlaceholderText="할 일을 입력하고 Enter — 예: 내일 오후 3시 회의 준비"
            Text="{x:Bind ViewModel.QuickAddText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <Grid Grid.Row="2">
            <ListView
                ItemTemplate="{StaticResource TaskRowTemplate}"
                ItemsSource="{x:Bind ViewModel.Tasks, Mode=OneWay}"
                SelectionMode="None"
                Visibility="{x:Bind ViewModel.IsStandardList, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <ListView.Footer>
                    <StackPanel
                        Margin="0,16,0,0"
                        Visibility="{x:Bind ViewModel.HasEveningTasks, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock
                            Margin="12,0,0,4"
                            Style="{StaticResource SubtitleTextBlockStyle}"
                            Text="This Evening" />
                        <ItemsControl
                            ItemTemplate="{StaticResource TaskRowTemplate}"
                            ItemsSource="{x:Bind ViewModel.EveningTasks, Mode=OneWay}" />
                    </StackPanel>
                </ListView.Footer>
            </ListView>

            <ListView
                ItemsSource="{x:Bind ViewModel.ProjectGroups, Mode=OneWay}"
                SelectionMode="None"
                Visibility="{x:Bind ViewModel.IsProjectMode, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="vm:TaskSectionGroupViewModel">
                        <StackPanel Margin="0,0,0,12">
                            <Grid Margin="12,4" ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Style="{StaticResource SubtitleTextBlockStyle}" Text="{x:Bind Name}" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Style="{StaticResource CaptionTextBlockStyle}"
                                        Text="{x:Bind DeadlineCaption}" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="4"
                                    Visibility="{x:Bind CanEdit, Converter={StaticResource BoolToVisibility}}">
                                    <Button Click="RenameSection_Click" Content="이름 변경" Tag="{x:Bind Id}" />
                                    <Button Click="DeleteSection_Click" Content="삭제" Tag="{x:Bind Id}" />
                                </StackPanel>
                            </Grid>
                            <ItemsControl
                                ItemTemplate="{StaticResource TaskRowTemplate}"
                                ItemsSource="{x:Bind Tasks}" />
                        </StackPanel>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <TextBlock
                Margin="4,8,0,0"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Text="표시할 할 일이 없습니다."
                Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
        </Grid>
    </Grid>
</Page>
