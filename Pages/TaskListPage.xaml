<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Cue.Pages.TaskListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Cue.ViewModels"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    FontFamily="{StaticResource CueFontFamily}"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Theme-aware interactive brushes: Color comes from a ThemeResource so it flips light/dark
             (fixes the old hardcoded #0F000000 hover that was invisible in dark mode). -->
        <StaticResource x:Key="TaskHoverBrush" ResourceKey="CueHoverFillBrush" />
        <StaticResource x:Key="TaskPressedBrush" ResourceKey="CuePressedFillBrush" />
        <SolidColorBrush x:Key="DetailCardBrush" Color="{ThemeResource CardBackgroundFillColorDefault}" />

        <Style x:Key="MetadataTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CueFontSecondary}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <DataTemplate x:Key="ChildTaskRowTemplate" x:DataType="vm:TaskRowViewModel">
            <Border
                Margin="0,1,4,1"
                Padding="12,6"
                Background="Transparent"
                CornerRadius="{StaticResource CueRadiusSmall}"
                Loaded="TaskSurface_Loaded"
                Opacity="{x:Bind VisualOpacity, Mode=OneWay}"
                PointerEntered="TaskSurface_PointerEntered"
                PointerExited="TaskSurface_PointerExited"
                Tapped="TaskSurface_Tapped"
                Tag="{x:Bind Id}">
                <Border.BackgroundTransition>
                    <BrushTransition Duration="0:0:0.083" />
                </Border.BackgroundTransition>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="3" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Rectangle
                        VerticalAlignment="Stretch"
                        Fill="{ThemeResource AccentFillColorDefaultBrush}"
                        RadiusX="1.5"
                        RadiusY="1.5"
                        Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                    <CheckBox
                        Grid.Column="1"
                        VerticalAlignment="Center"
                        IsChecked="{x:Bind IsCompleted, Mode=TwoWay}"
                        Style="{StaticResource CueCircleCheckBoxStyle}" />
                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="3">
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock MaxWidth="420" VerticalAlignment="Center" FontSize="{StaticResource CueFontRowSub}" Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                            <Border
                                Grid.Column="1"
                                Padding="6,1"
                                VerticalAlignment="Center"
                                Background="{x:Bind Priority, Converter={StaticResource PriorityToTint}}"
                                CornerRadius="9"
                                Visibility="{x:Bind HasPriority, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock FontSize="11" Foreground="{x:Bind Priority, Converter={StaticResource PriorityToBrush}}" Text="{x:Bind Priority, Converter={StaticResource PriorityToLabel}}" />
                            </Border>
                        </Grid>
                        <StackPanel Orientation="Horizontal" Spacing="10" Visibility="{x:Bind HasMetadata, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource MetadataTextStyle}" Text="{x:Bind Schedule}" Visibility="{x:Bind HasSchedule, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TaskRowTemplate" x:DataType="vm:TaskRowViewModel">
            <StackPanel HorizontalAlignment="Stretch">
                <Border
                    Margin="4,2"
                    Padding="12,8"
                    Background="Transparent"
                    CornerRadius="{StaticResource CueRadiusRow}"
                    Loaded="TaskSurface_Loaded"
                    Opacity="{x:Bind VisualOpacity, Mode=OneWay}"
                    PointerEntered="TaskSurface_PointerEntered"
                    PointerExited="TaskSurface_PointerExited"
                    Tapped="TaskSurface_Tapped"
                    Tag="{x:Bind Id}">
                    <Border.BackgroundTransition>
                        <BrushTransition Duration="0:0:0.083" />
                    </Border.BackgroundTransition>
                    <Border.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </Border.Transitions>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Rectangle
                            VerticalAlignment="Stretch"
                            Fill="{ThemeResource AccentFillColorDefaultBrush}"
                            RadiusX="1.5"
                            RadiusY="1.5"
                            Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                        <CheckBox
                            Grid.Column="1"
                            VerticalAlignment="Center"
                            IsChecked="{x:Bind IsCompleted, Mode=TwoWay}"
                            Style="{StaticResource CueCircleCheckBoxStyle}" />
                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="4">
                            <Grid ColumnSpacing="8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock MaxWidth="520" VerticalAlignment="Center" FontSize="{StaticResource CueFontRow}" Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                                <Border
                                    Grid.Column="1"
                                    Padding="7,1"
                                    VerticalAlignment="Center"
                                    Background="{x:Bind Priority, Converter={StaticResource PriorityToTint}}"
                                    CornerRadius="9"
                                    Visibility="{x:Bind HasPriority, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock FontSize="11" Foreground="{x:Bind Priority, Converter={StaticResource PriorityToBrush}}" Text="{x:Bind Priority, Converter={StaticResource PriorityToLabel}}" />
                                </Border>
                            </Grid>
                            <StackPanel Orientation="Horizontal" Spacing="12" Visibility="{x:Bind HasMetadata, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Style="{StaticResource MetadataTextStyle}" Text="{x:Bind Schedule}" Visibility="{x:Bind HasSchedule, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid Margin="31,0,0,7" Visibility="{x:Bind HasSubtasks, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Margin="0,2,0,3" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <ItemsRepeater
                        Grid.Column="1"
                        Margin="6,0,0,0"
                        ElementClearing="TaskRepeater_ElementClearing"
                        ElementPrepared="TaskRepeater_ElementPrepared"
                        ItemTemplate="{StaticResource ChildTaskRowTemplate}"
                        ItemsSource="{x:Bind Subtasks}" />
                </Grid>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,6" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource CuePageTitleTextStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.TitleCaption, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasTitleCaption, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
            <Button Grid.Column="1" Click="AddSection_Click" Content="섹션 추가" Visibility="{x:Bind ViewModel.IsProjectMode, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
        </Grid>

        <InfoBar x:Name="ErrorInfoBar" Grid.Row="1" Margin="4,0,4,8" IsClosable="True" IsOpen="False" Severity="Error" Title="작업을 완료하지 못했습니다" />

        <!-- Quick-add styled after the Files Omnibar: a floating pill with a CircleElevation border for
             subtle elevation (no drop shadow), centered text/icon, control-fill tone that lifts on
             hover and gains an accent ring on focus. -->
        <Grid Grid.Row="2" Margin="4,2,4,14">
            <TextBox
                MinHeight="48"
                Padding="46,11,14,11"
                VerticalContentAlignment="Center"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CircleElevationBorderBrush}"
                BorderThickness="1"
                CornerRadius="24"
                FontSize="15"
                IsEnabled="{x:Bind ViewModel.CanQuickAdd, Mode=OneWay}"
                KeyDown="QuickAdd_KeyDown"
                PlaceholderText="할 일을 입력하고 Enter — 예: 내일 오후 3시 회의 준비"
                Text="{x:Bind ViewModel.QuickAddText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <TextBox.Resources>
                    <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="ControlFillColorSecondaryBrush" />
                    <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="ControlFillColorDefaultBrush" />
                    <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="CircleElevationBorderBrush" />
                    <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="AccentFillColorDefaultBrush" />
                </TextBox.Resources>
            </TextBox>
            <FontIcon
                Margin="20,0,0,0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                FontSize="16"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                Glyph="&#xE710;"
                IsHitTestVisible="False" />
        </Grid>

        <Grid
            x:Name="ContentSplitGrid"
            Grid.Row="3"
            ColumnSpacing="16"
            SizeChanged="ContentSplitGrid_SizeChanged">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid>
                <ScrollViewer Visibility="{x:Bind ViewModel.IsStandardList, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <ItemsRepeater
                            ElementClearing="TaskRepeater_ElementClearing"
                            ElementPrepared="TaskRepeater_ElementPrepared"
                            ItemTemplate="{StaticResource TaskRowTemplate}"
                            ItemsSource="{x:Bind ViewModel.Tasks, Mode=OneWay}"
                            Loaded="ReorderRepeater_Loaded" />
                        <StackPanel Margin="0,18,0,0" Visibility="{x:Bind ViewModel.HasEveningTasks, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Margin="14,0,0,7" Style="{StaticResource CueSectionHeaderTextStyle}" Text="오늘 저녁" />
                            <ItemsRepeater
                                ElementClearing="TaskRepeater_ElementClearing"
                                ElementPrepared="TaskRepeater_ElementPrepared"
                                ItemTemplate="{StaticResource TaskRowTemplate}"
                                ItemsSource="{x:Bind ViewModel.EveningTasks, Mode=OneWay}"
                                Loaded="ReorderRepeater_Loaded" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ListView
                    ItemsSource="{x:Bind ViewModel.ProjectGroups, Mode=OneWay}"
                    SelectionMode="None"
                    Visibility="{x:Bind ViewModel.IsGroupedList, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskSectionGroupViewModel">
                            <StackPanel Margin="0,0,0,16">
                                <Grid Margin="14,5,8,7" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CueSectionHeaderTextStyle}" Text="{x:Bind Name}" />
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind DeadlineCaption}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Visibility="{x:Bind CanEdit, Converter={StaticResource BoolToVisibility}}">
                                        <Button Click="RenameSection_Click" Content="이름 변경" Style="{StaticResource CueSubtleTextButtonStyle}" Tag="{x:Bind Id}" />
                                        <Button Click="DeleteSection_Click" Content="삭제" Style="{StaticResource CueSubtleTextButtonStyle}" Tag="{x:Bind Id}" />
                                    </StackPanel>
                                </Grid>
                                <ItemsRepeater ElementClearing="TaskRepeater_ElementClearing" ElementPrepared="TaskRepeater_ElementPrepared" ItemTemplate="{StaticResource TaskRowTemplate}" ItemsSource="{x:Bind Tasks}" Loaded="ReorderRepeater_Loaded" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock
                    Margin="0,96,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="표시할 할 일이 없습니다."
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </Grid>

            <Border
                x:Name="DetailPanel"
                Grid.Column="1"
                Width="460"
                MinWidth="260"
                Margin="0,0,4,4"
                Padding="18,16,6,20"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CueRadiusPanel}"
                Loaded="DetailPanel_Loaded"
                SizeChanged="DetailPanel_SizeChanged"
                Visibility="{x:Bind ViewModel.Detail.IsOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <Border.Resources>
                    <!-- Detail controls use the same hover/press fill as task rows so interaction
                         color stays consistent across light and dark surfaces. -->
                    <ResourceDictionary>
                        <ResourceDictionary.ThemeDictionaries>
                            <ResourceDictionary x:Key="Light">
                                <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                            </ResourceDictionary>
                            <ResourceDictionary x:Key="Dark">
                                <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
                                <StaticResource x:Key="ComboBoxBackgroundPressed" ResourceKey="CuePressedFillBrush" />
                            </ResourceDictionary>
                        </ResourceDictionary.ThemeDictionaries>
                    </ResourceDictionary>
                </Border.Resources>
                <Grid>
                    <Rectangle
                        Width="10"
                        Margin="-18,0,0,0"
                        HorizontalAlignment="Left"
                        Canvas.ZIndex="3"
                        Fill="Transparent"
                        PointerMoved="DetailResizeHandle_PointerMoved"
                        PointerEntered="DetailResizeHandle_PointerEntered"
                        PointerExited="DetailResizeHandle_PointerExited"
                        PointerPressed="DetailResizeHandle_PointerPressed"
                        PointerReleased="DetailResizeHandle_PointerReleased"
                        PointerCanceled="DetailResizeHandle_PointerReleased" />
                    <Border
                        x:Name="DetailResizeGrip"
                        Width="4"
                        Height="58"
                        Margin="-15,0,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center"
                        Canvas.ZIndex="4"
                        Background="{ThemeResource TextFillColorTertiaryBrush}"
                        CornerRadius="2"
                        IsHitTestVisible="False"
                        Opacity="0">
                        <Border.OpacityTransition>
                            <ScalarTransition Duration="0:0:0.083" />
                        </Border.OpacityTransition>
                    </Border>
                    <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="2,0,16,0" Spacing="13">
                        <Button
                            HorizontalAlignment="Left"
                            Padding="2,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="OpenParent_Click"
                            Content="← 할 일로 돌아가기"
                            Visibility="{x:Bind ViewModel.Detail.HasParentTask, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                        <Grid ColumnSpacing="7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Padding="2,2,4,3"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="{StaticResource CueFontFamilySemiBold}"
                                FontSize="27"
                                PlaceholderText="할 일 제목"
                                Text="{x:Bind ViewModel.Detail.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                            <HyperlinkButton
                                Grid.Column="1"
                                Style="{StaticResource CueIconButtonStyle}"
                                Click="SaveDetail_Click"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                PointerEntered="IconAction_PointerEntered"
                                PointerExited="IconAction_PointerExited"
                                ToolTipService.ToolTip="저장"
                                AutomationProperties.Name="저장">
                                <HyperlinkButton.Resources>
                                    <SolidColorBrush x:Key="HyperlinkButtonForegroundPointerOver" Color="{ThemeResource SystemFillColorSuccess}" />
                                    <SolidColorBrush x:Key="HyperlinkButtonForegroundPressed" Opacity="0.6" Color="{ThemeResource SystemFillColorSuccess}" />
                                    <SolidColorBrush x:Key="HyperlinkButtonBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="HyperlinkButtonBackgroundPressed" Color="Transparent" />
                                </HyperlinkButton.Resources>
                                <FontIcon FontSize="18" Glyph="&#xE73E;" />
                            </HyperlinkButton>
                            <HyperlinkButton
                                Grid.Column="2"
                                Style="{StaticResource CueIconButtonStyle}"
                                Click="CloseDetail_Click"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                PointerEntered="IconAction_PointerEntered"
                                PointerExited="IconAction_PointerExited"
                                ToolTipService.ToolTip="닫기"
                                AutomationProperties.Name="닫기">
                                <HyperlinkButton.Resources>
                                    <SolidColorBrush x:Key="HyperlinkButtonForegroundPointerOver" Color="{ThemeResource SystemFillColorCritical}" />
                                    <SolidColorBrush x:Key="HyperlinkButtonForegroundPressed" Opacity="0.6" Color="{ThemeResource SystemFillColorCritical}" />
                                    <SolidColorBrush x:Key="HyperlinkButtonBackgroundPointerOver" Color="Transparent" />
                                    <SolidColorBrush x:Key="HyperlinkButtonBackgroundPressed" Color="Transparent" />
                                </HyperlinkButton.Resources>
                                <FontIcon FontSize="17" Glyph="&#xE711;" />
                            </HyperlinkButton>
                        </Grid>

                        <Border Margin="4,2,8,7" Padding="16" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="11">
                                <TextBox AcceptsReturn="True" MinHeight="92" PlaceholderText="메모를 추가하세요" Text="{x:Bind ViewModel.Detail.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                <Grid x:Name="DetailMetaGrid" ColumnSpacing="12" RowSpacing="10">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Spacing="5">
                                        <TextBlock Text="중요도" />
                                        <ComboBox HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.Detail.Priorities}" SelectedItem="{x:Bind ViewModel.Detail.SelectedPriority, Mode=TwoWay}">
                                            <ComboBox.ItemTemplate>
                                                <DataTemplate>
                                                    <TextBlock Text="{Binding Converter={StaticResource PriorityToLabel}}" />
                                                </DataTemplate>
                                            </ComboBox.ItemTemplate>
                                        </ComboBox>
                                    </StackPanel>
                                    <StackPanel x:Name="DetailProjectField" Grid.Column="1" Spacing="5"><TextBlock Text="그룹" /><ComboBox HorizontalAlignment="Stretch" DisplayMemberPath="Name" ItemsSource="{x:Bind ViewModel.Detail.Projects}" SelectedItem="{x:Bind ViewModel.Detail.SelectedProject, Mode=TwoWay}" /></StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- 시작일 + 마감일 are one card. Once a 시작일 is added it sits on top, above the
                             마감일 (the natural start→due order), separated by a divider; before that the
                             + 시작일 추가 button takes its place. A 시작일 can never be later than the
                             마감일 (WhenMaxDate cap). -->
                        <Border Margin="4,0,8,7" Padding="16" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="11">
                                <Button
                                    HorizontalAlignment="Left"
                                    Click="EnableWhen_Click"
                                    Content="+ 시작일 추가"
                                    Style="{StaticResource CueSubtleTextButtonStyle}"
                                    Visibility="{x:Bind ViewModel.Detail.CanAddWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                                <StackPanel Spacing="11" Visibility="{x:Bind ViewModel.Detail.IsWhenEditorVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <Grid>
                                        <TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="시작일" />
                                        <Button HorizontalAlignment="Right" Padding="8,3" Background="Transparent" BorderThickness="0" Click="ClearWhen_Click" Content="제거" />
                                    </Grid>
                                    <Grid x:Name="WhenDateTimeGrid" ColumnSpacing="8" RowSpacing="8" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CalendarDatePicker HorizontalAlignment="Stretch" Date="{x:Bind ViewModel.Detail.WhenDate, Mode=TwoWay}" MaxDate="{x:Bind ViewModel.Detail.WhenMaxDate, Mode=OneWay}" PlaceholderText="날짜 선택" />
                                        <StackPanel
                                            x:Name="WhenTimePanel"
                                            Grid.Column="1"
                                            VerticalAlignment="Center"
                                            Orientation="Horizontal"
                                            Spacing="7"
                                            Visibility="{x:Bind ViewModel.Detail.ShowWhenTime, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                            <ComboBox Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Hours}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenHour, Mode=TwoWay}" />
                                            <TextBlock VerticalAlignment="Center" FontSize="18" Text=":" />
                                            <ComboBox Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Minutes}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenMinute, Mode=TwoWay}" />
                                        </StackPanel>
                                    </Grid>
                                    <CheckBox Content="종일" IsChecked="{x:Bind ViewModel.Detail.IsWhenAllDay, Mode=TwoWay}" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                    <Rectangle Height="1" Margin="0,2" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                                </StackPanel>

                                <TextBlock Style="{StaticResource CueCardHeaderTextStyle}" Text="마감일" />
                                <Grid x:Name="DeadlineDateTimeGrid" ColumnSpacing="8" RowSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <CalendarDatePicker HorizontalAlignment="Stretch" Date="{x:Bind ViewModel.Detail.DeadlineDate, Mode=TwoWay}" PlaceholderText="날짜 선택" />
                                    <StackPanel
                                        x:Name="DeadlineTimePanel"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Orientation="Horizontal"
                                        Spacing="7"
                                        Visibility="{x:Bind ViewModel.Detail.ShowDeadlineTime, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                        <ComboBox Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Hours}" SelectedItem="{x:Bind ViewModel.Detail.SelectedDeadlineHour, Mode=TwoWay}" />
                                        <TextBlock VerticalAlignment="Center" FontSize="18" Text=":" />
                                        <ComboBox Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Minutes}" SelectedItem="{x:Bind ViewModel.Detail.SelectedDeadlineMinute, Mode=TwoWay}" />
                                    </StackPanel>
                                </Grid>
                                <CheckBox Content="종일" IsChecked="{x:Bind ViewModel.Detail.IsDeadlineAllDay, Mode=TwoWay}" Visibility="{x:Bind ViewModel.Detail.HasDeadline, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </Border>

                        <Border Margin="4,0,8,7" Padding="16" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="10">
                                <Grid><TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="태그" /><Button HorizontalAlignment="Right" Click="AddLabel_Click" Content="+ 새 태그" Style="{StaticResource CueSubtleTextButtonStyle}" /></Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Labels}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:LabelEditorOption">
                                            <Button
                                                Margin="0,1"
                                                Padding="8,7"
                                                HorizontalAlignment="Stretch"
                                                HorizontalContentAlignment="Stretch"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Click="LabelRow_Click"
                                                CornerRadius="{StaticResource CueRadiusSmall}"
                                                Tag="{x:Bind Id}">
                                                <Grid ColumnSpacing="10">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon VerticalAlignment="Center" FontSize="15" Foreground="{x:Bind Color, Converter={StaticResource HexToBrush}}" Glyph="&#xE8EC;" />
                                                    <Grid Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{x:Bind Name}" TextTrimming="Clip" />
                                                        <Rectangle
                                                            Width="24"
                                                            HorizontalAlignment="Right"
                                                            IsHitTestVisible="False">
                                                            <Rectangle.Fill>
                                                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                                    <GradientStop Offset="0" Color="Transparent" />
                                                                    <GradientStop Offset="1" Color="{ThemeResource CardBackgroundFillColorDefault}" />
                                                                </LinearGradientBrush>
                                                            </Rectangle.Fill>
                                                        </Rectangle>
                                                    </Grid>
                                                    <FontIcon Grid.Column="2" VerticalAlignment="Center" FontSize="14" Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" Glyph="&#xE73E;" Visibility="{x:Bind IsSelected, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                                </Grid>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Margin="4,0,8,8" Padding="16" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="11">
                                <TextBlock Style="{StaticResource CueCardHeaderTextStyle}" Text="체크리스트" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox PlaceholderText="체크리스트 항목" Text="{x:Bind ViewModel.Detail.NewSubtaskTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Click="AddSubtask_Click" Content="추가" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Subtasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SubtaskRowViewModel">
                                            <Grid Margin="0,1" Padding="0,2" ColumnSpacing="10" Opacity="{x:Bind VisualOpacity, Mode=OneWay}">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <CheckBox VerticalAlignment="Center" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" Style="{StaticResource CueCircleCheckBoxStyle}" />
                                                <Button Grid.Column="1" Padding="6,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Click="OpenSubtask_Click" Content="{x:Bind Title}" CornerRadius="{StaticResource CueRadiusSmall}" FontSize="{StaticResource CueFontRowSub}" Tag="{x:Bind Id}" />
                                                <Button Grid.Column="2" Width="32" Height="32" Padding="0" Background="Transparent" BorderThickness="0" Click="DeleteSubtask_Click" Tag="{x:Bind Id}" ToolTipService.ToolTip="삭제" AutomationProperties.Name="체크리스트 항목 삭제"><FontIcon FontSize="13" Glyph="&#xE74D;" /></Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                        </StackPanel>
                    </ScrollViewer>
                    <Rectangle
                        Height="26"
                        VerticalAlignment="Bottom"
                        IsHitTestVisible="False">
                        <Rectangle.Fill>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="Transparent" />
                                <GradientStop Offset="1" Color="{ThemeResource LayerFillColorDefault}" />
                            </LinearGradientBrush>
                        </Rectangle.Fill>
                    </Rectangle>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
