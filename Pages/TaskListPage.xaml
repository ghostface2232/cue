<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Cue.Pages.TaskListPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:Cue.ViewModels"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    FontFamily="{StaticResource CueFontFamily}"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Theme-aware interactive brushes: Color comes from a ThemeResource so it flips light/dark
             (fixes the old hardcoded #0F000000 hover that was invisible in dark mode). -->
        <SolidColorBrush x:Key="TaskHoverBrush" Color="{ThemeResource SubtleFillColorSecondary}" />
        <SolidColorBrush x:Key="TaskPressedBrush" Color="{ThemeResource SubtleFillColorTertiary}" />
        <SolidColorBrush x:Key="DetailCardBrush" Color="{ThemeResource CardBackgroundFillColorDefault}" />

        <Style x:Key="MetadataTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CueFontSecondary}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <DataTemplate x:Key="ChildTaskRowTemplate" x:DataType="vm:TaskRowViewModel">
            <Border
                Margin="0,1,4,1"
                Padding="12,6"
                Background="Transparent"
                CornerRadius="{StaticResource CueRadiusSmall}"
                Loaded="TaskSurface_Loaded"
                Opacity="{x:Bind VisualOpacity, Mode=OneWay}"
                PointerEntered="TaskSurface_PointerEntered"
                PointerExited="TaskSurface_PointerExited"
                Tapped="TaskSurface_Tapped"
                Tag="{x:Bind Id}">
                <Border.BackgroundTransition>
                    <BrushTransition Duration="0:0:0.083" />
                </Border.BackgroundTransition>
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <CheckBox
                        VerticalAlignment="Center"
                        IsChecked="{x:Bind IsCompleted, Mode=TwoWay}"
                        Style="{StaticResource CueCircleCheckBoxStyle}" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="3">
                        <TextBlock FontSize="{StaticResource CueFontRowSub}" Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                        <StackPanel Orientation="Horizontal" Spacing="10" Visibility="{x:Bind HasMetadata, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Style="{StaticResource MetadataTextStyle}" Text="{x:Bind Schedule}" Visibility="{x:Bind HasSchedule, Converter={StaticResource BoolToVisibility}}" />
                            <TextBlock Style="{StaticResource MetadataTextStyle}" Text="{x:Bind PriorityCaption}" Visibility="{x:Bind HasPriority, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate x:Key="TaskRowTemplate" x:DataType="vm:TaskRowViewModel">
            <StackPanel HorizontalAlignment="Stretch">
                <Border
                    Margin="4,2"
                    Padding="12,8"
                    Background="Transparent"
                    CornerRadius="{StaticResource CueRadiusRow}"
                    Loaded="TaskSurface_Loaded"
                    Opacity="{x:Bind VisualOpacity, Mode=OneWay}"
                    PointerEntered="TaskSurface_PointerEntered"
                    PointerExited="TaskSurface_PointerExited"
                    Tapped="TaskSurface_Tapped"
                    Tag="{x:Bind Id}">
                    <Border.BackgroundTransition>
                        <BrushTransition Duration="0:0:0.083" />
                    </Border.BackgroundTransition>
                    <Border.Transitions>
                        <TransitionCollection>
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </Border.Transitions>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <CheckBox
                            VerticalAlignment="Center"
                            IsChecked="{x:Bind IsCompleted, Mode=TwoWay}"
                            Style="{StaticResource CueCircleCheckBoxStyle}" />
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                            <TextBlock FontSize="{StaticResource CueFontRow}" Text="{x:Bind Title}" TextTrimming="CharacterEllipsis" />
                            <StackPanel Orientation="Horizontal" Spacing="12" Visibility="{x:Bind HasMetadata, Converter={StaticResource BoolToVisibility}}">
                                <TextBlock Style="{StaticResource MetadataTextStyle}" Text="{x:Bind Schedule}" Visibility="{x:Bind HasSchedule, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock Style="{StaticResource MetadataTextStyle}" Text="{x:Bind PriorityCaption}" Visibility="{x:Bind HasPriority, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock Style="{StaticResource MetadataTextStyle}" Text="{x:Bind SubtaskCaption}" Visibility="{x:Bind HasSubtasks, Converter={StaticResource BoolToVisibility}}" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>
                <Grid Margin="31,0,0,7" Visibility="{x:Bind HasSubtasks, Converter={StaticResource BoolToVisibility}}">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Rectangle Margin="0,2,0,3" Fill="{ThemeResource DividerStrokeColorDefaultBrush}" />
                    <ItemsRepeater
                        Grid.Column="1"
                        Margin="6,0,0,0"
                        ElementClearing="TaskRepeater_ElementClearing"
                        ElementPrepared="TaskRepeater_ElementPrepared"
                        ItemTemplate="{StaticResource ChildTaskRowTemplate}"
                        ItemsSource="{x:Bind Subtasks}" />
                </Grid>
            </StackPanel>
        </DataTemplate>
    </Page.Resources>

    <Grid Padding="28,20,28,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Margin="4,0,4,6" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Style="{StaticResource CuePageTitleTextStyle}" Text="{x:Bind ViewModel.Title, Mode=OneWay}" />
                <TextBlock
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Style="{StaticResource CaptionTextBlockStyle}"
                    Text="{x:Bind ViewModel.TitleCaption, Mode=OneWay}"
                    Visibility="{x:Bind ViewModel.HasTitleCaption, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
            <Button Grid.Column="1" Click="AddSection_Click" Content="섹션 추가" Visibility="{x:Bind ViewModel.IsProjectMode, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
        </Grid>

        <InfoBar x:Name="ErrorInfoBar" Grid.Row="1" Margin="4,0,4,8" IsClosable="True" IsOpen="False" Severity="Error" Title="작업을 완료하지 못했습니다" />

        <TextBox
            Grid.Row="2"
            Margin="4,0,4,12"
            Padding="14,8,8,8"
            MinHeight="40"
            CornerRadius="20"
            IsEnabled="{x:Bind ViewModel.CanQuickAdd, Mode=OneWay}"
            KeyDown="QuickAdd_KeyDown"
            PlaceholderText="할 일을 입력하고 Enter — 예: 내일 오후 3시 회의 준비"
            Text="{x:Bind ViewModel.QuickAddText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

        <Grid Grid.Row="3" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Grid>
                <ScrollViewer Visibility="{x:Bind ViewModel.IsStandardList, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <ItemsRepeater
                            ElementClearing="TaskRepeater_ElementClearing"
                            ElementPrepared="TaskRepeater_ElementPrepared"
                            ItemTemplate="{StaticResource TaskRowTemplate}"
                            ItemsSource="{x:Bind ViewModel.Tasks, Mode=OneWay}"
                            Loaded="ReorderRepeater_Loaded" />
                        <StackPanel Margin="0,18,0,0" Visibility="{x:Bind ViewModel.HasEveningTasks, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Margin="14,0,0,7" Style="{StaticResource CueSectionHeaderTextStyle}" Text="오늘 저녁" />
                            <ItemsRepeater
                                ElementClearing="TaskRepeater_ElementClearing"
                                ElementPrepared="TaskRepeater_ElementPrepared"
                                ItemTemplate="{StaticResource TaskRowTemplate}"
                                ItemsSource="{x:Bind ViewModel.EveningTasks, Mode=OneWay}"
                                Loaded="ReorderRepeater_Loaded" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>

                <ListView
                    ItemsSource="{x:Bind ViewModel.ProjectGroups, Mode=OneWay}"
                    SelectionMode="None"
                    Visibility="{x:Bind ViewModel.IsProjectMode, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="vm:TaskSectionGroupViewModel">
                            <StackPanel Margin="0,0,0,16">
                                <Grid Margin="14,5,8,7" ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Style="{StaticResource CueSectionHeaderTextStyle}" Text="{x:Bind Name}" />
                                        <TextBlock Foreground="{ThemeResource TextFillColorSecondaryBrush}" Style="{StaticResource CaptionTextBlockStyle}" Text="{x:Bind DeadlineCaption}" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" Visibility="{x:Bind CanEdit, Converter={StaticResource BoolToVisibility}}">
                                        <Button Click="RenameSection_Click" Content="이름 변경" Style="{StaticResource CueSubtleTextButtonStyle}" Tag="{x:Bind Id}" />
                                        <Button Click="DeleteSection_Click" Content="삭제" Style="{StaticResource CueSubtleTextButtonStyle}" Tag="{x:Bind Id}" />
                                    </StackPanel>
                                </Grid>
                                <ItemsRepeater ElementClearing="TaskRepeater_ElementClearing" ElementPrepared="TaskRepeater_ElementPrepared" ItemTemplate="{StaticResource TaskRowTemplate}" ItemsSource="{x:Bind Tasks}" Loaded="ReorderRepeater_Loaded" />
                            </StackPanel>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <TextBlock
                    Margin="0,96,0,0"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="표시할 할 일이 없습니다."
                    Visibility="{x:Bind ViewModel.IsEmpty, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
            </Grid>

            <Border
                x:Name="DetailPanel"
                Grid.Column="1"
                Width="460"
                Margin="0,0,4,4"
                Padding="18,16,6,20"
                Background="{ThemeResource LayerFillColorDefaultBrush}"
                BackgroundSizing="InnerBorderEdge"
                BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource CueRadiusPanel}"
                Loaded="DetailPanel_Loaded"
                Visibility="{x:Bind ViewModel.Detail.IsOpen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="2,0,16,0" Spacing="13">
                        <Button
                            HorizontalAlignment="Left"
                            Padding="2,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="OpenParent_Click"
                            Content="← 상위 작업으로 돌아가기"
                            Visibility="{x:Bind ViewModel.Detail.HasParentTask, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                        <Grid ColumnSpacing="7">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox
                                Padding="2,2,4,3"
                                VerticalAlignment="Center"
                                Background="Transparent"
                                BorderThickness="0"
                                FontFamily="{StaticResource CueFontFamilySemiBold}"
                                FontSize="27"
                                PlaceholderText="작업 제목"
                                Text="{x:Bind ViewModel.Detail.Title, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                TextWrapping="Wrap" />
                            <HyperlinkButton
                                Grid.Column="1"
                                Style="{StaticResource CueIconButtonStyle}"
                                Click="SaveDetail_Click"
                                Foreground="{ThemeResource SystemFillColorSuccessBrush}"
                                PointerEntered="IconAction_PointerEntered"
                                PointerExited="IconAction_PointerExited"
                                ToolTipService.ToolTip="저장"
                                AutomationProperties.Name="저장">
                                <FontIcon FontSize="18" Glyph="&#xE73E;" />
                            </HyperlinkButton>
                            <HyperlinkButton
                                Grid.Column="2"
                                Style="{StaticResource CueIconButtonStyle}"
                                Click="CloseDetail_Click"
                                Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                PointerEntered="IconAction_PointerEntered"
                                PointerExited="IconAction_PointerExited"
                                ToolTipService.ToolTip="닫기"
                                AutomationProperties.Name="닫기">
                                <FontIcon FontSize="17" Glyph="&#xE711;" />
                            </HyperlinkButton>
                        </Grid>

                        <Border Margin="4,2,8,7" Padding="16" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="11">
                                <TextBlock Style="{StaticResource CueCardHeaderTextStyle}" Text="작업 정보" />
                                <TextBox AcceptsReturn="True" MinHeight="92" PlaceholderText="메모를 추가하세요" Text="{x:Bind ViewModel.Detail.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" TextWrapping="Wrap" />
                                <Grid ColumnSpacing="12">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                    <StackPanel Spacing="5"><TextBlock Text="우선순위" /><ComboBox HorizontalAlignment="Stretch" ItemsSource="{x:Bind ViewModel.Detail.Priorities}" SelectedItem="{x:Bind ViewModel.Detail.SelectedPriority, Mode=TwoWay}" /></StackPanel>
                                    <StackPanel Grid.Column="1" Spacing="5"><TextBlock Text="프로젝트" /><ComboBox HorizontalAlignment="Stretch" DisplayMemberPath="Name" ItemsSource="{x:Bind ViewModel.Detail.Projects}" SelectedItem="{x:Bind ViewModel.Detail.SelectedProject, Mode=TwoWay}" /></StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Button
                            HorizontalAlignment="Left"
                            Margin="4,0,0,2"
                            Click="EnableWhen_Click"
                            Content="+ 예정 추가"
                            Style="{StaticResource CueSubtleTextButtonStyle}"
                            Visibility="{x:Bind ViewModel.Detail.CanAddWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />

                        <Border Margin="4,0,8,7" Padding="16" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge" Visibility="{x:Bind ViewModel.Detail.IsWhenEditorVisible, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Spacing="11">
                                <Grid>
                                    <TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="예정" />
                                    <Button HorizontalAlignment="Right" Padding="8,3" Background="Transparent" BorderThickness="0" Click="ClearWhen_Click" Content="제거" />
                                </Grid>
                                <CalendarDatePicker HorizontalAlignment="Stretch" Date="{x:Bind ViewModel.Detail.WhenDate, Mode=TwoWay}" PlaceholderText="날짜 선택" />
                                <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="시각" />
                                    <Grid ColumnSpacing="7">
                                        <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /></Grid.ColumnDefinitions>
                                        <ComboBox Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Hours}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenHour, Mode=TwoWay}" />
                                        <TextBlock Grid.Column="1" VerticalAlignment="Center" FontSize="18" Text=":" />
                                        <ComboBox Grid.Column="2" Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Minutes}" SelectedItem="{x:Bind ViewModel.Detail.SelectedWhenMinute, Mode=TwoWay}" />
                                    </Grid>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="18">
                                    <CheckBox Content="저녁" IsChecked="{x:Bind ViewModel.Detail.IsEvening, Mode=TwoWay}" Visibility="{x:Bind ViewModel.Detail.HasConcreteWhen, Mode=OneWay, Converter={StaticResource BoolToVisibility}}" />
                                    <CheckBox Content="언젠가" IsChecked="{x:Bind ViewModel.Detail.IsSomeday, Mode=TwoWay}" />
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="4,0,8,7" Padding="16" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="11">
                                <TextBlock Style="{StaticResource CueCardHeaderTextStyle}" Text="마감" />
                                <CalendarDatePicker HorizontalAlignment="Stretch" Date="{x:Bind ViewModel.Detail.DeadlineDate, Mode=TwoWay}" PlaceholderText="날짜 선택" />
                                <StackPanel Spacing="6" Visibility="{x:Bind ViewModel.Detail.HasDeadline, Mode=OneWay, Converter={StaticResource BoolToVisibility}}">
                                    <TextBlock Text="시각" />
                                    <StackPanel Orientation="Horizontal" Spacing="7">
                                        <ComboBox Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Hours}" SelectedItem="{x:Bind ViewModel.Detail.SelectedDeadlineHour, Mode=TwoWay}" />
                                        <TextBlock VerticalAlignment="Center" FontSize="18" Text=":" />
                                        <ComboBox Width="72" DisplayMemberPath="Label" ItemsSource="{x:Bind ViewModel.Detail.Minutes}" SelectedItem="{x:Bind ViewModel.Detail.SelectedDeadlineMinute, Mode=TwoWay}" />
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Margin="4,0,8,7" Padding="16" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="10">
                                <Grid><TextBlock VerticalAlignment="Center" Style="{StaticResource CueCardHeaderTextStyle}" Text="라벨" /><Button HorizontalAlignment="Right" Click="AddLabel_Click" Content="+ 새 라벨" Style="{StaticResource CueSubtleTextButtonStyle}" /></Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Labels}">
                                    <ItemsControl.ItemsPanel><ItemsPanelTemplate><ItemsWrapGrid Orientation="Horizontal" /></ItemsPanelTemplate></ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate><DataTemplate x:DataType="vm:LabelEditorOption"><CheckBox Margin="0,0,14,7" Content="{x:Bind Name}" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" /></DataTemplate></ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Margin="4,0,8,8" Padding="16" Background="{StaticResource DetailCardBrush}" CornerRadius="{StaticResource CueRadiusCard}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" BackgroundSizing="InnerBorderEdge">
                            <StackPanel Spacing="11">
                                <TextBlock Style="{StaticResource CueCardHeaderTextStyle}" Text="서브태스크" />
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                    <TextBox PlaceholderText="서브태스크 제목" Text="{x:Bind ViewModel.Detail.NewSubtaskTitle, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Grid.Column="1" Click="AddSubtask_Click" Content="추가" />
                                </Grid>
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Detail.Subtasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="vm:SubtaskRowViewModel">
                                            <Grid Margin="0,3" Padding="2,5" ColumnSpacing="10" Opacity="{x:Bind VisualOpacity, Mode=OneWay}">
                                                <Grid.ColumnDefinitions><ColumnDefinition Width="Auto" /><ColumnDefinition Width="*" /><ColumnDefinition Width="Auto" /></Grid.ColumnDefinitions>
                                                <CheckBox VerticalAlignment="Center" IsChecked="{x:Bind IsCompleted, Mode=TwoWay}" />
                                                <Button Grid.Column="1" Padding="8,6" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" Background="Transparent" BorderThickness="0" Click="OpenSubtask_Click" Content="{x:Bind Title}" Tag="{x:Bind Id}" />
                                                <Button Grid.Column="2" Width="32" Height="32" Padding="0" Click="DeleteSubtask_Click" Tag="{x:Bind Id}" ToolTipService.ToolTip="삭제" AutomationProperties.Name="서브태스크 삭제"><FontIcon FontSize="13" Glyph="&#xE74D;" /></Button>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</Page>
