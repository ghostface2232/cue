<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="Cue.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Cue.Pages"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:Cue.Behaviors"
    Background="{ThemeResource LayerFillColorDefaultBrush}"
    FontFamily="{StaticResource CueFontFamily}"
    mc:Ignorable="d">

    <Page.Resources>
        <!-- Section navigation: mirrors the sidebar's calm, flattened selection (subtle fill +
             primary text, no accent text) so the two nav surfaces read the same. The 4px side inset
             floats the rounded highlight inside the column (same as the main list's 4,1 row margin and
             the sidebar's item inset) so all four corners round visibly instead of running flush to —
             and being clipped at — the nav's edges.

             Custom template (replacing the stock ListViewItemPresenter) so the highlight reads exactly
             like the rest of the app:
               • Hover/press fill fades on the SAME 83ms BrushTransition as the main list rows, instead
                 of the presenter's slower stock timing.
               • A selected item DEEPENS on hover/press (Secondary → Tertiary), matching the documented
                 cross-surface rule the sidebar and main list follow (see DesignTokens "deepen").
               • Selection is shown by a left accent bar (same language as the sidebar/main list). -->
        <Style x:Key="SettingsNavItemStyle" TargetType="ListViewItem">
            <Setter Property="MinHeight" Value="38" />
            <Setter Property="Margin" Value="4,2" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="CornerRadius" Value="{StaticResource CueRadiusRow}" />
            <Setter Property="FocusVisualMargin" Value="2" />
            <Setter Property="FocusVisualPrimaryThickness" Value="1" />
            <Setter Property="FocusVisualSecondaryThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListViewItem">
                        <Grid x:Name="Root" Background="Transparent" Control.IsTemplateFocusTarget="True">
                            <!-- The hover/selection pill. BackgroundTransition gives the same soft 83ms
                                 fade the main list rows use; VisualState.Setters swap the fill per state. -->
                            <Border x:Name="HoverBg" Background="Transparent" CornerRadius="{TemplateBinding CornerRadius}">
                                <Border.BackgroundTransition>
                                    <BrushTransition Duration="0:0:0.083" />
                                </Border.BackgroundTransition>
                            </Border>
                            <!-- Left accent bar shown on selection (sidebar/main-list language). Stretches
                                 with the item height, inset top/bottom so it reads as a short pill. -->
                            <Rectangle
                                x:Name="SelectionBar"
                                Width="3"
                                Margin="0,8"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Stretch"
                                Fill="{ThemeResource AccentFillColorDefaultBrush}"
                                Opacity="0"
                                RadiusX="1.5"
                                RadiusY="1.5" />
                            <ContentPresenter
                                x:Name="ContentPresenter"
                                Padding="{TemplateBinding Padding}"
                                HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                VerticalContentAlignment="{TemplateBinding VerticalContentAlignment}"
                                Content="{TemplateBinding Content}"
                                ContentTemplate="{TemplateBinding ContentTemplate}"
                                ContentTransitions="{TemplateBinding ContentTransitions}" />

                            <VisualStateManager.VisualStateGroups>
                                <VisualStateGroup x:Name="CommonStates">
                                    <VisualState x:Name="Normal" />
                                    <VisualState x:Name="PointerOver">
                                        <VisualState.Setters>
                                            <Setter Target="HoverBg.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Pressed">
                                        <VisualState.Setters>
                                            <Setter Target="HoverBg.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="Selected">
                                        <VisualState.Setters>
                                            <Setter Target="HoverBg.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                            <Setter Target="SelectionBar.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <!-- Selected + hover/press DEEPEN to Tertiary (the cross-surface rule). -->
                                    <VisualState x:Name="PointerOverSelected">
                                        <VisualState.Setters>
                                            <Setter Target="HoverBg.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                            <Setter Target="SelectionBar.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <VisualState x:Name="PressedSelected">
                                        <VisualState.Setters>
                                            <Setter Target="HoverBg.Background" Value="{ThemeResource SubtleFillColorTertiaryBrush}" />
                                            <Setter Target="SelectionBar.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                    <!-- Keep the bar lit when the selected item loses focus (e.g. clicking a control). -->
                                    <VisualState x:Name="SelectedUnfocused">
                                        <VisualState.Setters>
                                            <Setter Target="HoverBg.Background" Value="{ThemeResource SubtleFillColorSecondaryBrush}" />
                                            <Setter Target="SelectionBar.Opacity" Value="1" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                                <VisualStateGroup x:Name="DisabledStates">
                                    <VisualState x:Name="Enabled" />
                                    <VisualState x:Name="Disabled">
                                        <VisualState.Setters>
                                            <Setter Target="Root.Opacity" Value="0.5" />
                                        </VisualState.Setters>
                                    </VisualState>
                                </VisualStateGroup>
                            </VisualStateManager.VisualStateGroups>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SettingsNavTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CueFontRowSub}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingsNavGlyphStyle" TargetType="FontIcon">
            <Setter Property="Width" Value="18" />
            <Setter Property="FontSize" Value="15" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        </Style>

        <!-- Row label (= the detail-panel card header), allowed to wrap when the label column is
             narrow so a long label never forces the card wider. -->
        <Style x:Key="SettingsRowHeaderStyle" TargetType="TextBlock" BasedOn="{StaticResource CueCardHeaderTextStyle}">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>

        <!-- Quietest label tone for the right column captions (= MetadataTextStyle elsewhere). -->
        <Style x:Key="SettingsCaptionStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="{StaticResource CueFontSecondary}" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextWrapping" Value="Wrap" />
            <Setter Property="LineHeight" Value="17" />
        </Style>

        <!-- Left text column of a settings row: label + caption, vertically centered against the
             trailing control, width-capped (shared token) so captions wrap at a comfortable measure. -->
        <Style x:Key="SettingsLabelColumnStyle" TargetType="StackPanel">
            <Setter Property="Spacing" Value="{StaticResource CueGap4}" />
            <Setter Property="MaxWidth" Value="{StaticResource CueSettingsLabelMaxWidth}" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <!-- One settings row = [label/caption *] [control Auto, flush right]. -->
        <Style x:Key="SettingsRowStyle" TargetType="Grid">
            <Setter Property="MinHeight" Value="{StaticResource CueSettingsRowMinHeight}" />
            <Setter Property="ColumnSpacing" Value="{StaticResource CueGap24}" />
        </Style>

        <!-- Trailing control sits centered and flush to the card's inner edge, at a shared fixed
             width and the small (4px) control radius so every section's control aligns and rounds
             the same. -->
        <Style x:Key="SettingsControlStyle" TargetType="Control">
            <Setter Property="Width" Value="{StaticResource CueSettingsControlWidth}" />
            <Setter Property="CornerRadius" Value="{StaticResource CueRadiusSmall}" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="SettingsCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="{StaticResource CuePadCard}" />
            <Setter Property="CornerRadius" Value="{StaticResource CueRadiusCard}" />
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BackgroundSizing" Value="InnerBorderEdge" />
        </Style>

        <!-- Full-bleed separator between rows inside a 16-padded card. -->
        <Style x:Key="SettingsDividerStyle" TargetType="Border">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="-16,0" />
            <Setter Property="Background" Value="{ThemeResource DividerStrokeColorDefaultBrush}" />
        </Style>

        <!-- Calm toggle: strip the framework's English On/Off content; the label lives on the left. -->
        <Style x:Key="SettingsToggleStyle" TargetType="ToggleSwitch">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="OnContent" Value="" />
            <Setter Property="OffContent" Value="" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
    </Page.Resources>

    <!-- Uniform body padding (CuePadPage) to match the list and timeline pages (see DESIGN "Layout"). -->
    <Grid Padding="{StaticResource CuePadPage}" RowSpacing="{StaticResource CueGap16}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Margin="4,0,0,2"
            Style="{StaticResource CuePageTitleTextStyle}"
            Text="설정" />

        <Grid Grid.Row="1" Margin="4,0,0,0" ColumnSpacing="{StaticResource CueGap24}">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <ListView
                x:Name="SectionNav"
                Width="{StaticResource CueSettingsNavWidth}"
                VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Padding="0"
                Background="Transparent"
                IsItemClickEnabled="False"
                ItemContainerStyle="{StaticResource SettingsNavItemStyle}"
                SelectionChanged="SectionNav_SelectionChanged"
                SelectionMode="Single"
                SelectedIndex="0">
                <ListViewItem Tag="Time">
                    <Grid ColumnSpacing="{StaticResource CueGap8}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE823;" Style="{StaticResource SettingsNavGlyphStyle}" />
                        <TextBlock Grid.Column="1" Style="{StaticResource SettingsNavTextStyle}" Text="시간" />
                    </Grid>
                </ListViewItem>
                <ListViewItem Tag="Parsing">
                    <Grid ColumnSpacing="{StaticResource CueGap8}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE943;" Style="{StaticResource SettingsNavGlyphStyle}" />
                        <TextBlock Grid.Column="1" Style="{StaticResource SettingsNavTextStyle}" Text="파싱" />
                    </Grid>
                </ListViewItem>
                <ListViewItem Tag="Appearance">
                    <Grid ColumnSpacing="{StaticResource CueGap8}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE790;" Style="{StaticResource SettingsNavGlyphStyle}" />
                        <TextBlock Grid.Column="1" Style="{StaticResource SettingsNavTextStyle}" Text="외관" />
                    </Grid>
                </ListViewItem>
                <ListViewItem Tag="Notifications">
                    <Grid ColumnSpacing="{StaticResource CueGap8}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <FontIcon Glyph="&#xE7F4;" Style="{StaticResource SettingsNavGlyphStyle}" />
                        <TextBlock Grid.Column="1" Style="{StaticResource SettingsNavTextStyle}" Text="알림" />
                    </Grid>
                </ListViewItem>
            </ListView>

            <ScrollViewer
                Grid.Column="1"
                Padding="0,0,0,8"
                behaviors:ScrollBarAutoHide.IsEnabled="True"
                HorizontalScrollBarVisibility="Disabled"
                VerticalScrollBarVisibility="Auto">
                <!-- Fill the whole column (variable width), exactly as the main content area fills the
                     space beside the sidebar — no max-width cap, so a wider window gives the cards more
                     room instead of leaving the right side empty. Plain Stretch fills left-to-right, so
                     there is no centering (which WinUI would do under Stretch + MaxWidth, opening a nav
                     gap and pushing the right cards under the scrollbar). Each row still reads cleanly:
                     the label column is width-capped so captions wrap, and the trailing control is a
                     fixed width flush right, so a wide card just widens the gap between them. -->
                <Grid HorizontalAlignment="Stretch">
                    <!-- 시간 -->
                    <StackPanel
                        x:Name="TimeSection"
                        Spacing="{StaticResource CueGap12}"
                        Visibility="Visible">
                        <TextBlock
                            Margin="2,0,0,2"
                            Style="{StaticResource CueSectionHeaderTextStyle}"
                            Text="시간" />

                        <Border Style="{StaticResource SettingsCardStyle}">
                            <!-- Stacked rows: symmetric vertical padding fixes the gap to the divider so a
                                 one-line caption (주 시작 요일) and a wrapping one (기본 시간대) read the same.
                                 Centering inside MinHeight alone broke this — the taller row lost its top slack. -->
                            <StackPanel Spacing="0">
                                <Grid Padding="0,8" Style="{StaticResource SettingsRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Style="{StaticResource SettingsLabelColumnStyle}">
                                        <TextBlock Style="{StaticResource SettingsRowHeaderStyle}" Text="주 시작 요일" />
                                        <TextBlock Style="{StaticResource SettingsCaptionStyle}" Text="주간 보기와 달력 선택에서 먼저 오는 요일" />
                                    </StackPanel>
                                    <ComboBox
                                        x:Name="FirstDayCombo"
                                        Grid.Column="1"
                                        Style="{StaticResource SettingsControlStyle}"
                                        SelectionChanged="FirstDayCombo_SelectionChanged" />
                                </Grid>

                                <Border Style="{StaticResource SettingsDividerStyle}" />

                                <Grid Padding="0,8" Style="{StaticResource SettingsRowStyle}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Style="{StaticResource SettingsLabelColumnStyle}">
                                        <TextBlock Style="{StaticResource SettingsRowHeaderStyle}" Text="기본 시간대" />
                                        <TextBlock Style="{StaticResource SettingsCaptionStyle}" Text="오늘, 앞으로 할 일, 빠른 입력 날짜 기준. 다음 실행부터 전체 반영" />
                                    </StackPanel>
                                    <ComboBox
                                        x:Name="TimeZoneCombo"
                                        Grid.Column="1"
                                        Style="{StaticResource SettingsControlStyle}"
                                        SelectionChanged="TimeZoneCombo_SelectionChanged" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 파싱 -->
                    <StackPanel
                        x:Name="ParsingSection"
                        Spacing="{StaticResource CueGap12}"
                        Visibility="Collapsed">
                        <TextBlock
                            Margin="2,0,0,2"
                            Style="{StaticResource CueSectionHeaderTextStyle}"
                            Text="파싱" />

                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid Style="{StaticResource SettingsRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Style="{StaticResource SettingsLabelColumnStyle}">
                                    <TextBlock Style="{StaticResource SettingsRowHeaderStyle}" Text="1–6시를 오후로 해석" />
                                    <TextBlock Style="{StaticResource SettingsCaptionStyle}" Text="오전/오후가 없을 때 3시는 15:00으로 저장" />
                                </StackPanel>
                                <ToggleSwitch
                                    x:Name="AutoAfternoonSwitch"
                                    Grid.Column="1"
                                    Style="{StaticResource SettingsToggleStyle}"
                                    Toggled="AutoAfternoonSwitch_Toggled" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel Spacing="{StaticResource CueGap16}">
                                <StackPanel Spacing="{StaticResource CueGap4}">
                                    <TextBlock Style="{StaticResource SettingsRowHeaderStyle}" Text="커스텀 날짜 의미" />
                                    <TextBlock Style="{StaticResource SettingsCaptionStyle}" Text="입력에서 인식할 매월 반복 날짜를 직접 추가합니다" />
                                </StackPanel>

                                <Border Style="{StaticResource SettingsDividerStyle}" />

                                <TextBlock
                                    x:Name="CustomDatesEmptyHint"
                                    Margin="0,2"
                                    Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                    FontSize="{StaticResource CueFontRowSub}"
                                    Text="아직 추가한 날짜가 없습니다"
                                    Visibility="Collapsed" />
                                <ListView
                                    x:Name="CustomDatesList"
                                    MaxHeight="220"
                                    Margin="-8,-4"
                                    SelectionMode="None">
                                    <ListView.ItemContainerStyle>
                                        <Style TargetType="ListViewItem">
                                            <Setter Property="MinHeight" Value="0" />
                                            <Setter Property="Padding" Value="8,8" />
                                            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                            <Setter Property="CornerRadius" Value="{StaticResource CueRadiusSmall}" />
                                        </Style>
                                    </ListView.ItemContainerStyle>
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="local:CustomDateMeaningRow">
                                            <Grid ColumnSpacing="{StaticResource CueGap12}" MinHeight="36">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel VerticalAlignment="Center" Spacing="{StaticResource CueGap2}">
                                                    <TextBlock FontSize="{StaticResource CueFontRowSub}" Text="{x:Bind Name}" />
                                                    <TextBlock Style="{StaticResource SettingsCaptionStyle}" Text="{x:Bind DayCaption}" />
                                                </StackPanel>
                                                <Button
                                                    Grid.Column="1"
                                                    VerticalAlignment="Center"
                                                    Tag="{x:Bind Name}"
                                                    Click="RemoveCustomDate_Click"
                                                    Content="삭제"
                                                    Style="{StaticResource CueSubtleTextButtonStyle}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>

                                <Grid ColumnSpacing="{StaticResource CueGap8}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="112" />
                                        <ColumnDefinition Width="74" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox
                                        x:Name="CustomDateNameBox"
                                        VerticalAlignment="Center"
                                        PlaceholderText="예: 월급날" />
                                    <NumberBox
                                        x:Name="CustomDateDayBox"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Minimum="1"
                                        Maximum="31"
                                        PlaceholderText="일"
                                        SpinButtonPlacementMode="Inline" />
                                    <Button
                                        Grid.Column="2"
                                        HorizontalAlignment="Stretch"
                                        VerticalAlignment="Center"
                                        Click="AddCustomDate_Click"
                                        Content="추가" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 외관 -->
                    <StackPanel
                        x:Name="AppearanceSection"
                        Spacing="{StaticResource CueGap12}"
                        Visibility="Collapsed">
                        <TextBlock
                            Margin="2,0,0,2"
                            Style="{StaticResource CueSectionHeaderTextStyle}"
                            Text="외관" />

                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid Style="{StaticResource SettingsRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Style="{StaticResource SettingsLabelColumnStyle}">
                                    <TextBlock Style="{StaticResource SettingsRowHeaderStyle}" Text="화면 모드" />
                                    <TextBlock Style="{StaticResource SettingsCaptionStyle}" Text="시스템, 라이트, 다크" />
                                </StackPanel>
                                <ComboBox
                                    x:Name="ThemeCombo"
                                    Grid.Column="1"
                                    Style="{StaticResource SettingsControlStyle}"
                                    SelectionChanged="ThemeCombo_SelectionChanged" />
                            </Grid>
                        </Border>

                        <Border Style="{StaticResource SettingsCardStyle}">
                            <StackPanel Spacing="{StaticResource CueGap16}">
                                <StackPanel Spacing="{StaticResource CueGap4}">
                                    <TextBlock Style="{StaticResource SettingsRowHeaderStyle}" Text="강조 컬러" />
                                    <TextBlock Style="{StaticResource SettingsCaptionStyle}" Text="선택 표시, 체크, 포커스 링에만 사용" />
                                </StackPanel>
                                <StackPanel
                                    x:Name="AccentSwatches"
                                    Orientation="Horizontal"
                                    Spacing="{StaticResource CueGap8}" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- 알림 -->
                    <StackPanel
                        x:Name="NotificationsSection"
                        Spacing="{StaticResource CueGap12}"
                        Visibility="Collapsed">
                        <TextBlock
                            Margin="2,0,0,2"
                            Style="{StaticResource CueSectionHeaderTextStyle}"
                            Text="알림" />

                        <Border Style="{StaticResource SettingsCardStyle}">
                            <Grid Style="{StaticResource SettingsRowStyle}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Style="{StaticResource SettingsLabelColumnStyle}">
                                    <TextBlock Style="{StaticResource SettingsRowHeaderStyle}" Text="리마인더" />
                                    <TextBlock Style="{StaticResource SettingsCaptionStyle}" Text="리마인더 구현 단계에서 활성화" />
                                </StackPanel>
                                <ToggleSwitch
                                    Grid.Column="1"
                                    IsEnabled="False"
                                    Style="{StaticResource SettingsToggleStyle}" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
