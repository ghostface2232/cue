<?xml version="1.0" encoding="utf-8" ?>
<!--
    Cue design tokens — distilled from the Files app analysis (see DESIGN_REF.md).
    Principle: build on WinUI's theme-aware tokens, never hardcode ARGB. Brushes resolve their
    Color from a {ThemeResource ...Color} so they flip correctly between light and dark.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== Typeface: Pretendard JP (Korean-first). Static OTFs ship as two families — true
         SemiBold lives in its own family, so weight hierarchy switches family, not FontWeight. ===== -->
    <FontFamily x:Key="CueFontFamily">ms-appx:///Assets/Fonts/PretendardJP-Regular.otf#Pretendard JP</FontFamily>
    <FontFamily x:Key="CueFontFamilySemiBold">ms-appx:///Assets/Fonts/PretendardJP-SemiBold.otf#Pretendard JP SemiBold</FontFamily>
    <!-- Make Pretendard the default for templated controls (buttons, list items, text boxes, nav…).
         Plain TextBlocks inherit it via FontFamily set on the window root in MainWindow.xaml. -->
    <FontFamily x:Key="ContentControlThemeFontFamily">ms-appx:///Assets/Fonts/PretendardJP-Regular.otf#Pretendard JP</FontFamily>

    <!-- ===== Text hierarchy: family(weight) + size + color in one style each ===== -->
    <Style x:Key="CuePageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource CueFontFamilySemiBold}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="CueSectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource CueFontFamilySemiBold}" />
        <Setter Property="FontSize" Value="{StaticResource CueFontSection}" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="CueCardHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource CueFontFamilySemiBold}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <!-- ===== Radius scale (4 / 8 / 12, mirroring Files' ControlCornerRadius / OverlayCornerRadius) ===== -->
    <CornerRadius x:Key="CueRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="CueRadiusRow">8</CornerRadius>
    <CornerRadius x:Key="CueRadiusCard">8</CornerRadius>
    <CornerRadius x:Key="CueRadiusPanel">12</CornerRadius>

    <!-- ===== Type scale (page 28 → section 16 → row 15 → secondary 12) ===== -->
    <x:Double x:Key="CueFontSection">16</x:Double>
    <x:Double x:Key="CueFontRow">15</x:Double>
    <x:Double x:Key="CueFontRowSub">14</x:Double>
    <x:Double x:Key="CueFontSecondary">12</x:Double>

    <!-- Interactive-state brushes (TaskHoverBrush / TaskPressedBrush / DetailCardBrush) are kept
         page-local in TaskListPage so the page code-behind can resolve them via this.Resources. -->

    <!-- ===== Priority cue colors (Todoist-style row dot). Theme-aware via ThemeResource on Color;
         resolved by PriorityToBrushConverter. ===== -->
    <SolidColorBrush x:Key="CuePriorityP1Brush" Color="{ThemeResource SystemFillColorCritical}" />
    <SolidColorBrush x:Key="CuePriorityP2Brush" Color="{ThemeResource SystemFillColorCaution}" />
    <SolidColorBrush x:Key="CuePriorityP3Brush" Color="{ThemeResource SystemAccentColor}" />
    <SolidColorBrush x:Key="CuePriorityP4Brush" Color="{ThemeResource TextFillColorTertiary}" />

    <!-- ===== Flatten text inputs: remove the Fluent bottom "accent bar" (the focused 2px bottom
         border and the resting gradient) so all input fields read as calm, uniform 1px boxes.
         Alias the stock Brush resources directly; TextBox visual states consume Brush values. ===== -->
    <Thickness x:Key="TextControlBorderThemeThickness">1</Thickness>
    <Thickness x:Key="TextControlBorderThemeThicknessFocused">1</Thickness>
    <StaticResource x:Key="TextControlBorderBrush" ResourceKey="ControlStrokeColorDefaultBrush" />
    <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="ControlStrokeColorDefaultBrush" />
    <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="ControlStrokeColorDefaultBrush" />
    <!-- A persistent tone so inputs read as distinct from the page/cards, one step deeper on hover.
         Focused keeps the tone instead of the default bright white-out. -->
    <StaticResource x:Key="TextControlBackground" ResourceKey="ControlFillColorDefaultBrush" />
    <StaticResource x:Key="TextControlBackgroundPointerOver" ResourceKey="ControlFillColorSecondaryBrush" />
    <StaticResource x:Key="TextControlBackgroundFocused" ResourceKey="ControlFillColorDefaultBrush" />

    <!-- ===== NavigationView: flatten the selected-item text to primary (calmer, Things-3-like).
         Mirrors Files/Settings NavigationViewItemButtonStyle. Overrides the stock keys app-wide;
         theme-correct because the Color is itself a ThemeResource. ===== -->
    <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="{ThemeResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver" Color="{ThemeResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed" Color="{ThemeResource TextFillColorPrimary}" />

    <!-- ===== Shared icon button (transparent at rest, colored glyph) ===== -->
    <Style x:Key="CueIconButtonStyle" TargetType="HyperlinkButton">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource CueRadiusSmall}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- ===== Subtle text button for tertiary inline actions ===== -->
    <Style x:Key="CueSubtleTextButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="{StaticResource CueRadiusSmall}" />
    </Style>

    <!-- ===== Things-3-style circular completion check =====
         Outline circle (unchecked) → filled accent circle + checkmark (checked), with a satisfying
         overshoot "pop". Apply only to completion checkboxes, not multi-select/label checkboxes. -->
    <Style x:Key="CueCircleCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid x:Name="RootGrid" Background="Transparent" Padding="2">
                        <Grid
                            x:Name="CheckContainer"
                            Width="20"
                            Height="20"
                            RenderTransformOrigin="0.5,0.5">
                            <Grid.RenderTransform>
                                <ScaleTransform x:Name="CheckScale" />
                            </Grid.RenderTransform>
                            <Ellipse
                                x:Name="Outline"
                                Width="20"
                                Height="20"
                                Stroke="{ThemeResource TextFillColorTertiaryBrush}"
                                StrokeThickness="1.6" />
                            <Ellipse
                                x:Name="Fill"
                                Width="20"
                                Height="20"
                                Opacity="0"
                                Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                            <FontIcon
                                x:Name="Glyph"
                                FontSize="11"
                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                Glyph="&#xE73E;"
                                Opacity="0" />
                        </Grid>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CombinedStates">
                                <VisualState x:Name="UncheckedNormal" />
                                <VisualState x:Name="UncheckedPointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Outline" Storyboard.TargetProperty="Stroke">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="UncheckedPressed" />
                                <VisualState x:Name="UncheckedDisabled">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RootGrid"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.4"
                                            Duration="0" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="CheckedNormal">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Fill"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.12" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glyph"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0:0:0.12" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Outline"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0:0:0.12" />
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleX">
                                            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.6" />
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.1,0.9 0.2,1.0"
                                                KeyTime="0:0:0.18"
                                                Value="1.15" />
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.2,0 0,1"
                                                KeyTime="0:0:0.28"
                                                Value="1.0" />
                                        </DoubleAnimationUsingKeyFrames>
                                        <DoubleAnimationUsingKeyFrames Storyboard.TargetName="CheckScale" Storyboard.TargetProperty="ScaleY">
                                            <DiscreteDoubleKeyFrame KeyTime="0:0:0" Value="0.6" />
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.1,0.9 0.2,1.0"
                                                KeyTime="0:0:0.18"
                                                Value="1.15" />
                                            <SplineDoubleKeyFrame
                                                KeySpline="0.2,0 0,1"
                                                KeyTime="0:0:0.28"
                                                Value="1.0" />
                                        </DoubleAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="CheckedPointerOver">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Fill"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glyph"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Outline"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="CheckedPressed">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Fill"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glyph"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Outline"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0" />
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="CheckedDisabled">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="Fill"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Glyph"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1"
                                            Duration="0" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="Outline"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0"
                                            Duration="0" />
                                        <DoubleAnimation
                                            Storyboard.TargetName="RootGrid"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.4"
                                            Duration="0" />
                                    </Storyboard>
                                </VisualState>

                                <VisualState x:Name="IndeterminateNormal" />
                                <VisualState x:Name="IndeterminatePointerOver" />
                                <VisualState x:Name="IndeterminatePressed" />
                                <VisualState x:Name="IndeterminateDisabled">
                                    <Storyboard>
                                        <DoubleAnimation
                                            Storyboard.TargetName="RootGrid"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.4"
                                            Duration="0" />
                                    </Storyboard>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
