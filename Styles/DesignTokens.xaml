<?xml version="1.0" encoding="utf-8" ?>
<!--
    Cue design tokens — distilled from the Files app analysis (see DESIGN_REF.md).
    Principle: build on WinUI's theme-aware tokens, never hardcode ARGB. Brushes resolve their
    Color from a {ThemeResource ...Color} so they flip correctly between light and dark.
-->
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Input field tone: theme-split. Light keeps the standard control fill (and holds that
         tone on focus instead of the default bright white-out). Dark uses a subtle recessed (darker)
         well rather than the framework's translucent-white fill, which read as too bright on the dark
         cards. Consumed by TextBox visual states. -->
    <ResourceDictionary.ThemeDictionaries>
        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="TextControlBackground" Color="{ThemeResource ControlFillColorDefault}" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{ThemeResource ControlFillColorSecondary}" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{ThemeResource ControlFillColorDefault}" />
            <!-- Destructive (delete/confirm) red. Light keeps the system critical tone, which is a proper
                 deep red here. Dark splits to its own literal red because the system critical color in dark
                 is a washed-out pink (#FF99A4) — too soft to read as a destructive action. -->
            <SolidColorBrush x:Key="CueDangerFillBrush" Color="{ThemeResource SystemFillColorCritical}" />
            <!-- Neutral chip fill (group chip on a task row). A small dark overlay reads as a calm gray
                 pill on the light page/cards regardless of the surface beneath it. The tag chip uses a
                 tint of its own color instead (HexToTint); this neutral is only for the group chip. -->
            <SolidColorBrush x:Key="CueChipNeutralFillBrush" Color="#14000000" />
            <!-- Selected sidebar item + hover/press must DEEPEN, matching the main list (where a
                 selected row's hover stacks two SubtleFillColorSecondary layers). The stock
                 NavigationView selected-pointer-over tone is lighter than the selected tone, which
                 read as the opposite of the list. These theme-scoped literals approximate that
                 double-stack (the only place the rule is unavoidable as a literal). -->
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="#12000000" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPressed" Color="#18000000" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="HighContrast">
            <SolidColorBrush x:Key="TextControlBackground" Color="{ThemeResource ControlFillColorDefault}" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="{ThemeResource ControlFillColorSecondary}" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="{ThemeResource ControlFillColorDefault}" />
            <SolidColorBrush x:Key="CueDangerFillBrush" Color="{ThemeResource SystemFillColorCritical}" />
            <SolidColorBrush x:Key="CueChipNeutralFillBrush" Color="#14000000" />
        </ResourceDictionary>
        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="TextControlBackground" Color="#18000000" />
            <SolidColorBrush x:Key="TextControlBackgroundPointerOver" Color="#24000000" />
            <SolidColorBrush x:Key="TextControlBackgroundFocused" Color="#18000000" />
            <!-- A clean, saturated red for dark surfaces (the system critical color is pink here). -->
            <SolidColorBrush x:Key="CueDangerFillBrush" Color="#D13438" />
            <!-- Dark counterpart of the neutral group-chip fill (white overlay). See Light note. -->
            <SolidColorBrush x:Key="CueChipNeutralFillBrush" Color="#18FFFFFF" />
            <!-- Dark counterpart of the deepen-on-hover selection (white overlay). See Light note. -->
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPointerOver" Color="#1DFFFFFF" />
            <SolidColorBrush x:Key="NavigationViewItemBackgroundSelectedPressed" Color="#28FFFFFF" />
        </ResourceDictionary>
    </ResourceDictionary.ThemeDictionaries>

    <!-- Typeface: Pretendard JP (Korean-first). Static OTFs ship as two families — true
         SemiBold lives in its own family, so weight hierarchy switches family, not FontWeight. -->
    <FontFamily x:Key="CueFontFamily">ms-appx:///Assets/Fonts/PretendardJP-Regular.otf#Pretendard JP</FontFamily>
    <!-- Medium is the emphasis weight for important content text that would otherwise read as Regular
         (list task titles, checklist item titles): clearer than Regular, lighter than the
         SemiBold reserved for headers. Like the others it ships as its own static-OTF family. -->
    <FontFamily x:Key="CueFontFamilyMedium">ms-appx:///Assets/Fonts/PretendardJP-Medium.otf#Pretendard JP Medium</FontFamily>
    <FontFamily x:Key="CueFontFamilySemiBold">ms-appx:///Assets/Fonts/PretendardJP-SemiBold.otf#Pretendard JP SemiBold</FontFamily>
    <!-- Make Pretendard the default for templated controls (buttons, list items, text boxes, nav…).
         Plain TextBlocks inherit it via FontFamily set on the window root in MainWindow.xaml. -->
    <FontFamily x:Key="ContentControlThemeFontFamily">ms-appx:///Assets/Fonts/PretendardJP-Regular.otf#Pretendard JP</FontFamily>

    <!-- Text hierarchy: family(weight) + size + color in one style each -->
    <Style x:Key="CuePageTitleTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource CueFontFamilySemiBold}" />
        <Setter Property="FontSize" Value="28" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>
    <Style x:Key="CueSectionHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource CueFontFamilySemiBold}" />
        <Setter Property="FontSize" Value="{StaticResource CueFontSection}" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>
    <!-- 중요도 view bucket header (매우 중요 / 중요 / …): a muted, smaller category caption that reads
         clearly apart from the larger task titles below it — gray (secondary) at the meta size. -->
    <Style x:Key="CuePriorityGroupHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource CueFontFamilySemiBold}" />
        <Setter Property="FontSize" Value="{StaticResource CueFontListMeta}" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
    </Style>
    <Style x:Key="CueCardHeaderTextStyle" TargetType="TextBlock">
        <Setter Property="FontFamily" Value="{StaticResource CueFontFamilySemiBold}" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
    </Style>

    <!-- Radius scale (4 / 8 / 12, mirroring Files' ControlCornerRadius / OverlayCornerRadius) -->
    <CornerRadius x:Key="CueRadiusSmall">4</CornerRadius>
    <CornerRadius x:Key="CueRadiusRow">8</CornerRadius>
    <CornerRadius x:Key="CueRadiusCard">8</CornerRadius>
    <CornerRadius x:Key="CueRadiusPanel">12</CornerRadius>
    <!-- Squircle (rounded-rectangle) radius for the group/tag/priority chips on a task row. Fixed at 8
         rather than a half-height pill so short chips (icon + 2 chars) read as a clean rounded rect, not
         an oval — the pill ends would meet on a narrow chip and look like an ellipse. -->
    <CornerRadius x:Key="CueRadiusChip">8</CornerRadius>
    <!-- Every chip/pill element on a task row (group, tag, priority) shares ONE fixed height with
         content vertically centered, so they line up exactly regardless of glyph/font differences.
         Horizontal-only padding keeps the height purely a function of this token. -->
    <x:Double x:Key="CueChipHeight">26</x:Double>
    <Thickness x:Key="CuePadChip">9,0</Thickness>

    <!-- Type scale (page 28 → section 16 → row 15 → secondary 12) -->
    <x:Double x:Key="CueFontSection">16</x:Double>
    <x:Double x:Key="CueFontRow">15</x:Double>
    <x:Double x:Key="CueFontRowSub">14</x:Double>
    <x:Double x:Key="CueFontSecondary">12</x:Double>

    <!-- Main list rows read larger and clearer than the base row scale: a 16 title (Medium) and a 13 meta
         line (date · time), with the rows themselves given more height (see TaskListPage padding). -->
    <x:Double x:Key="CueFontListTitle">16</x:Double>
    <x:Double x:Key="CueFontListMeta">13</x:Double>

    <!-- Sidebar group/tag rows: the hover/selection pill, the icon, and the label are positioned
         independently (see NavRow_Loaded, which sets these directly on the presenter's LayoutRoot /
         ContentGrid / ContentPresenter so they actually apply over the NavigationView nesting indent).
         The highlight pill starts from the stock 4px NavigationView row gutter. The right side gets
         a 1px optical compensation because it sits against the content separator. -->
    <x:Double x:Key="CueNavPillLeft">4</x:Double>
    <!-- Child rows nested under the Groups/Tags sections get a deeper left gutter than top-level rows,
         so the hierarchy reads at a glance. Top-level rows keep CueNavPillLeft. -->
    <x:Double x:Key="CueNavChildPillLeft">12</x:Double>
    <x:Double x:Key="CueNavPillRight">5</x:Double>
    <!-- The accent selection bar + content sit inside PresenterContentRootGrid / ContentGrid, which the
         NavigationView would indent on its own when the pane is open. We pin both to a zero left inset so
         the icon, highlight, and accent bar stay flush to the pill's content edge in BOTH pane states —
         the collapsed geometry is the reference, so nothing shifts horizontally when the pane toggles.
         Only the label keeps a small left gap (it has no collapsed counterpart to match against). -->
    <x:Double x:Key="CueNavLabelLeft">4</x:Double>
    <!-- Gap between the group/tag section expand-collapse chevron glyph and the row's right edge, in px
         (0 = flush). Layered on top of the framework's -14 flush margin in ApplyNavRowInsetForCurrentPane. -->
    <x:Double x:Key="CueNavChevronRight">8</x:Double>
    <!-- The open-task count badge on group/tag rows otherwise hugs the row's right edge; inset it. -->
    <x:Double x:Key="CueNavBadgeRight">8</x:Double>
    <!-- Opacity for the 그룹 없음 / 태그 없음 rows' icon — a faded group/tag glyph marks them as the
         catch-all bucket without the harder visual weight of a real group/tag. -->
    <x:Double x:Key="CueNavUnfiledIconOpacity">0.4</x:Double>

    <!-- Settings page layout
         The settings screen is the one place with its own section-nav + form rhythm. These tokens
         pin its column widths, control sizing, and row height so captions wrap at a comfortable length
         instead of running the card too wide, and the form matches the rest of the app's 16/20 spacing.
         The form column itself is NOT capped — it fills the space beside the nav (variable width), the
         same way the main content area fills the space beside the sidebar; a wider window gives the
         cards more room rather than leaving the right side empty.
         - NavWidth      : left section list, wide enough to hold the longest label + icon as a pill
         - LabelMaxWidth : caps the label/caption text column so captions wrap, not run on one line
         - ControlWidth  : fixed width of the trailing control (combo/etc.) so all rows align
         - RowMinHeight  : single-line row height, keeping a settled vertical rhythm -->
    <x:Double x:Key="CueSettingsNavWidth">200</x:Double>
    <x:Double x:Key="CueSettingsLabelMaxWidth">380</x:Double>
    <x:Double x:Key="CueSettingsControlWidth">200</x:Double>
    <x:Double x:Key="CueSettingsRowMinHeight">52</x:Double>

    <!-- Spacing scale
         The one rhythm for gaps and padding across every surface. Replaces the inline literals that
         used to drift (5/7/10/11/13/14…); off-scale values are snapped to the nearest rung so the UI
         reads from a small, intentional set. Two consumers, two resource types:
           • Gaps  (Spacing / ColumnSpacing / RowSpacing — Double) → the CueGap* x:Double tokens.
           • Padding / Margin (Thickness)                         → the CuePad* Thickness tokens.
         A Thickness resource is a fixed 4-tuple (no partial override), so a few structural/optical
         values stay inline by design — negative full-bleed margins, the quick-add omnibar's optical
         padding, empty-state centering offsets, the priority-pill inset, and sub-2px nudges. The
         CueNav* offsets above are optical corrections, NOT rhythm — they are deliberately not part of
         this scale. -->
    <x:Double x:Key="CueGap2">2</x:Double>
    <x:Double x:Key="CueGap4">4</x:Double>
    <x:Double x:Key="CueGap8">8</x:Double>
    <x:Double x:Key="CueGap12">12</x:Double>
    <x:Double x:Key="CueGap16">16</x:Double>
    <x:Double x:Key="CueGap20">20</x:Double>
    <x:Double x:Key="CueGap24">24</x:Double>

    <!-- Page body padding (uniform 20, = xl). The list and settings pages share it. -->
    <Thickness x:Key="CuePadPage">20</Thickness>
    <!-- Detail inner-card padding (uniform 16, = lg). Sits beside CueRadiusCard on the same Border. -->
    <Thickness x:Key="CuePadCard">16</Thickness>
    <!-- Checklist text inputs: horizontal inset snapped to 8 (sm), vertical 4 (xs). -->
    <Thickness x:Key="CuePadInput">8,4</Thickness>
    <!-- Detail panel content padding. Tuned around the scroll body + left resize strip (small 6 on the
         right where the scrollbar lives); centralized verbatim, never snapped. -->
    <Thickness x:Key="CuePadDetailPanel">18,16,6,20</Thickness>
    <!-- Detail-card stack margins: a deliberate vertical rhythm a single token can't express —
         first card leads in with a 2px top, the run uses 7 between, the last card closes with 8. -->
    <Thickness x:Key="CuePadDetailCardFirst">4,2,8,7</Thickness>
    <Thickness x:Key="CuePadDetailCard">4,0,8,7</Thickness>
    <Thickness x:Key="CuePadDetailCardLast">4,0,8,8</Thickness>

    <!-- Shared hover language. Main list rows, subtle buttons, and local panel
         controls all use the same fill so light mode does not drift between surfaces. -->
    <SolidColorBrush x:Key="CueHoverFillBrush" Color="{ThemeResource SubtleFillColorSecondary}" />
    <SolidColorBrush x:Key="CuePressedFillBrush" Color="{ThemeResource SubtleFillColorTertiary}" />
    <StaticResource x:Key="ButtonBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
    <StaticResource x:Key="ButtonBackgroundPressed" ResourceKey="CuePressedFillBrush" />

    <!-- Scrollbars: keep the stock Fluent template, but tune the visual thumb globally. The color is
         the platform strong fill with opacity, so light/dark stay theme-correct while reading softer. -->
    <x:Double x:Key="ScrollBarVerticalThumbMinWidth">4</x:Double>
    <x:Double x:Key="ScrollBarHorizontalThumbMinHeight">4</x:Double>
    <x:Double x:Key="ScrollBarThumbStrokeThickness">0</x:Double>
    <SolidColorBrush x:Key="ScrollBarThumbBackground" Color="{ThemeResource ControlStrongFillColorDefault}" Opacity="0.50" />
    <SolidColorBrush x:Key="ScrollBarPanningThumbBackground" Color="{ThemeResource ControlStrongFillColorDefault}" Opacity="0.50" />
    <SolidColorBrush x:Key="ScrollBarThumbFill" Color="{ThemeResource ControlStrongFillColorDefault}" Opacity="0.50" />
    <SolidColorBrush x:Key="ScrollBarThumbFillPointerOver" Color="{ThemeResource ControlStrongFillColorDefault}" Opacity="0.62" />
    <SolidColorBrush x:Key="ScrollBarThumbFillPressed" Color="{ThemeResource ControlStrongFillColorDefault}" Opacity="0.74" />

    <!-- HyperlinkButton shares the exact same hover/press language as Button, so icon buttons
         (e.g. the detail panel close button) read identically to every other button: a quiet
         background fill, no accent-colored or specially-animated hover. Foreground deepens to
         primary on hover instead of the stock accent tint. -->
    <StaticResource x:Key="HyperlinkButtonBackgroundPointerOver" ResourceKey="CueHoverFillBrush" />
    <StaticResource x:Key="HyperlinkButtonBackgroundPressed" ResourceKey="CuePressedFillBrush" />
    <SolidColorBrush x:Key="HyperlinkButtonForegroundPointerOver" Color="{ThemeResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="HyperlinkButtonForegroundPressed" Color="{ThemeResource TextFillColorSecondary}" />

    <!-- DetailCardBrush is kept page-local in TaskListPage so the page code-behind can resolve it
         via this.Resources. -->

    <!-- Destructive action tone (CueDangerFillBrush) is theme-split in the ThemeDictionaries at the top
         of this file: Light uses the system critical red; Dark uses a clean literal red because the system
         critical color is a washed-out pink on dark surfaces. -->

    <!-- Priority cue colors (Todoist-style row dot). Theme-aware via ThemeResource on Color;
         resolved by PriorityToBrushConverter. -->
    <SolidColorBrush x:Key="CuePriorityP1Brush" Color="{ThemeResource SystemFillColorCritical}" />
    <SolidColorBrush x:Key="CuePriorityP2Brush" Color="{ThemeResource SystemFillColorCaution}" />
    <SolidColorBrush x:Key="CuePriorityP3Brush" Color="{ThemeResource SystemAccentColor}" />
    <SolidColorBrush x:Key="CuePriorityP4Brush" Color="{ThemeResource TextFillColorTertiary}" />

    <!-- Flatten text inputs: remove the Fluent bottom "accent bar" (the focused 2px bottom
         border and the resting gradient) so all input fields read as calm, uniform 1px boxes.
         Alias the stock Brush resources directly; TextBox visual states consume Brush values. -->
    <Thickness x:Key="TextControlBorderThemeThickness">1</Thickness>
    <Thickness x:Key="TextControlBorderThemeThicknessFocused">1</Thickness>
    <StaticResource x:Key="TextControlBorderBrush" ResourceKey="ControlStrokeColorDefaultBrush" />
    <StaticResource x:Key="TextControlBorderBrushPointerOver" ResourceKey="ControlStrokeColorDefaultBrush" />
    <!-- On focus the border shifts to the accent (the documented rule). This is now global, so every text
         input — notes, inline new-tag, settings fields, inline group/tag create+rename — shows the same
         clear accent focus ring, matching the quick-add. Rest/hover stay the flat 1px ControlStroke. -->
    <StaticResource x:Key="TextControlBorderBrushFocused" ResourceKey="AccentFillColorDefaultBrush" />
    <!-- A persistent tone so inputs read as distinct from the page/cards, one step deeper on hover,
         holding the tone on focus instead of the default bright white-out. The actual background
         brushes are theme-split in the ThemeDictionaries at the top of this file. -->

    <!-- NavigationView: flatten the selected-item text to primary (calmer, Things-3-like).
         Mirrors Files/Settings NavigationViewItemButtonStyle. Overrides the stock keys app-wide;
         theme-correct because the Color is itself a ThemeResource. -->
    <Thickness x:Key="NavigationViewItemContentPresenterMargin">4,-1,4,-1</Thickness>
    <SolidColorBrush x:Key="NavigationViewItemForegroundSelected" Color="{ThemeResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPointerOver" Color="{ThemeResource TextFillColorPrimary}" />
    <SolidColorBrush x:Key="NavigationViewItemForegroundSelectedPressed" Color="{ThemeResource TextFillColorPrimary}" />

    <!-- Title bar pane-toggle (hamburger) button. The stock TitleBarPaneToggleButtonStyle is 40 wide
         (NavigationBackButtonWidth) with a 2px margin — wider than the app's 34px icon buttons and the
         sidebar rows, and its glyph sits a couple px left of the nav rail's natural icon column. Override it
         to a 34px button that shares the sidebar's hover/press language (CueHoverFill / CuePressedFill), and
         set the left margin to 7.5 so the centered glyph lands exactly on the nav icons' natural x — the nav
         rows themselves are left untouched, so alignment holds in both pane states. -->
    <Style x:Key="TitleBarPaneToggleButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimaryBrush}" />
        <Setter Property="FontFamily" Value="{ThemeResource SymbolThemeFontFamily}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="Width" Value="34" />
        <Setter Property="Margin" Value="7.5,2,2,2" />
        <Setter Property="VerticalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
        <Setter Property="CornerRadius" Value="{StaticResource CueRadiusSmall}" />
        <Setter Property="Content" Value="&#xE700;" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid x:Name="RootGrid" Background="{TemplateBinding Background}" CornerRadius="{TemplateBinding CornerRadius}">
                        <Grid.BackgroundTransition>
                            <BrushTransition Duration="0:0:0.083" />
                        </Grid.BackgroundTransition>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal" />
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource CueHoverFillBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootGrid.Background" Value="{ThemeResource CuePressedFillBrush}" />
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled" />
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                        <FontIcon
                            FontFamily="{TemplateBinding FontFamily}"
                            FontSize="{TemplateBinding FontSize}"
                            Foreground="{TemplateBinding Foreground}"
                            Glyph="&#xE700;"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Shared icon button (transparent at rest, colored glyph) -->
    <Style x:Key="CueIconButtonStyle" TargetType="HyperlinkButton">
        <Setter Property="Width" Value="34" />
        <Setter Property="Height" Value="34" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="CornerRadius" Value="{StaticResource CueRadiusSmall}" />
        <Setter Property="HorizontalContentAlignment" Value="Center" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <!-- Nav count badge
         The group/tag/unfiled open-task counts read as a quiet number, not an alert: no colored pill or
         circle, just tertiary digits aligned to the right of the row. (An attention-tinted pill made the
         counts look like unread-notification badges.) Retemplated with a TextBlock using
         TextLineBounds="Tight" so Pretendard's tall ascent doesn't sit the digit high. Numeric only. -->
    <Style x:Key="CueCountInfoBadgeStyle" TargetType="InfoBadge">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiaryBrush}" />
        <Setter Property="HorizontalAlignment" Value="Center" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Height" Value="16" />
        <Setter Property="MinWidth" Value="12" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="InfoBadge">
                    <Border
                        Background="{TemplateBinding Background}"
                        Height="{TemplateBinding Height}"
                        MinWidth="{TemplateBinding MinWidth}"
                        Padding="2,0">
                        <!-- Value (Int32) → Text (String) needs a converting binding: TemplateBinding does
                             no type coercion, so it would silently render blank. A TemplatedParent Binding
                             coerces to string (ToString) and shows the number. -->
                        <TextBlock
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontSize="{TemplateBinding FontSize}"
                            Foreground="{TemplateBinding Foreground}"
                            Text="{Binding Value, RelativeSource={RelativeSource TemplatedParent}}"
                            TextLineBounds="Tight" />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Subtle text button for tertiary inline actions -->
    <Style x:Key="CueSubtleTextButtonStyle" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
        <Setter Property="Padding" Value="8,4" />
        <Setter Property="CornerRadius" Value="{StaticResource CueRadiusSmall}" />
    </Style>

    <!-- Confirm popover (reusable anchored confirm — see Services/ConfirmPopover.cs).
         A light, contextual alternative to a centered ContentDialog for one-line confirmations
         ("삭제하시겠습니까?"): it anchors to the row/button that triggered it, the primary button
         or Enter confirms, and Esc / a click outside cancels. These tokens pin the presenter chrome
         and inner rhythm so every call site (task / group / tag / checklist delete) reads the same.
         The inner layout (message + right-aligned 취소·삭제 buttons) is built in the helper; the
         destructive primary button reuses AccentButtonStyle recolored to CueDangerFillBrush. -->
    <x:Double x:Key="CuePopoverMinWidth">236</x:Double>
    <x:Double x:Key="CuePopoverMaxWidth">300</x:Double>
    <Thickness x:Key="CuePadPopover">16,14,16,14</Thickness>
    <Style x:Key="CueConfirmPopoverPresenterStyle" TargetType="FlyoutPresenter">
        <Setter Property="Padding" Value="{StaticResource CuePadPopover}" />
        <Setter Property="MinWidth" Value="{StaticResource CuePopoverMinWidth}" />
        <Setter Property="MaxWidth" Value="{StaticResource CuePopoverMaxWidth}" />
        <Setter Property="CornerRadius" Value="{StaticResource CueRadiusCard}" />
        <Setter Property="ScrollViewer.HorizontalScrollMode" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollMode" Value="Disabled" />
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled" />
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
    </Style>

    <!-- Things-3-style circular completion check
         Outline circle (unchecked) → filled accent circle + checkmark (checked), with a satisfying
         overshoot "pop". Apply only to completion checkboxes, not multi-select/label checkboxes. -->
    <Style x:Key="CueCircleCheckBoxStyle" TargetType="CheckBox">
        <Setter Property="MinWidth" Value="0" />
        <Setter Property="MinHeight" Value="0" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalAlignment" Value="Center" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="CheckBox">
                    <Grid x:Name="RootGrid" Background="Transparent" Padding="2">
                        <Grid
                            x:Name="CheckContainer"
                            Width="20"
                            Height="20">
                            <Ellipse
                                x:Name="Outline"
                                Width="20"
                                Height="20"
                                Stroke="{ThemeResource TextFillColorTertiaryBrush}"
                                StrokeThickness="1.6" />
                            <Ellipse
                                x:Name="Fill"
                                Width="20"
                                Height="20"
                                Opacity="0"
                                Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                            <FontIcon
                                x:Name="Glyph"
                                FontSize="11"
                                Foreground="{ThemeResource TextOnAccentFillColorPrimaryBrush}"
                                Glyph="&#xE73E;"
                                Opacity="0" />
                        </Grid>

                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CombinedStates">
                                <VisualState x:Name="UncheckedNormal" />
                                <VisualState x:Name="UncheckedPointerOver">
                                    <Storyboard>
                                        <ObjectAnimationUsingKeyFrames Storyboard.TargetName="Outline" Storyboard.TargetProperty="Stroke">
                                            <DiscreteObjectKeyFrame KeyTime="0" Value="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </ObjectAnimationUsingKeyFrames>
                                    </Storyboard>
                                </VisualState>
                                <VisualState x:Name="UncheckedPressed" />
                                <VisualState x:Name="UncheckedDisabled">
                                    <Storyboard>
                                        <DoubleAnimation
