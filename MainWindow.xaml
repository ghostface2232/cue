<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="Cue.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:Cue"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:behaviors="using:Cue.Behaviors"
    Title="Cue"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TitleBar
            x:Name="AppTitleBar"
            FontFamily="{StaticResource CueFontFamily}"
            Title="Cue"
            BackRequested="TitleBar_BackRequested"
            IsBackButtonVisible="{x:Bind NavFrame.CanGoBack, Mode=OneWay}"
            IsPaneToggleButtonVisible="True"
            PaneToggleRequested="TitleBar_PaneToggleRequested">
            <TitleBar.Resources>
                <Style x:Key="CaptionTextBlockStyle" TargetType="TextBlock">
                    <Setter Property="FontFamily" Value="{StaticResource CueFontFamilyMedium}" />
                    <Setter Property="FontSize" Value="12" />
                    <Setter Property="TextTrimming" Value="CharacterEllipsis" />
                    <Setter Property="TextWrapping" Value="NoWrap" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
            </TitleBar.Resources>
        </TitleBar>

        <NavigationView
            x:Name="NavView"
            Grid.Row="1"
            behaviors:ScrollBarAutoHide.IsEnabled="True"
            behaviors:ScrollBarAutoHide.ReserveGutter="False"
            FontFamily="{StaticResource CueFontFamily}"
            IsBackButtonVisible="Collapsed"
            IsPaneToggleButtonVisible="False"
            IsSettingsVisible="False"
            ExpandedModeThresholdWidth="880"
            CompactModeThresholdWidth="640"
            OpenPaneLength="216"
            RightTapped="NavView_RightTapped"
            SelectionChanged="NavView_SelectionChanged">
            <NavigationView.MenuItems>
                <NavigationViewItem
                    x:Name="CueItem"
                    Content="모든 할 일"
                    IsSelected="True"
                    Tag="alltasks">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="TodayItem" Content="오늘 할 일" Tag="today">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8BF;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="UpcomingItem" Content="앞으로 할 일" Tag="upcoming">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE823;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="AnytimeItem" Content="언젠가 할 일" Tag="anytime">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8FD;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="LogbookItem" Content="완료한 일" Tag="logbook">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE73E;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="PriorityItem" Content="중요도" Tag="priority">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7C1;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItemSeparator />
                <NavigationViewItem
                    x:Name="GroupsSection"
                    HorizontalContentAlignment="Stretch"
                    IsExpanded="True"
                    SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                    </NavigationViewItem.Icon>
                    <!-- The "new group" action is a + button on the section header, immediately left of the
                         expand/collapse chevron — not a list row. -->
                    <NavigationViewItem.Content>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource CueFontFamilySemiBold}"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="그룹" />
                            <Button
                                Grid.Column="1"
                                Width="26"
                                Height="26"
                                Margin="0,0,4,0"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="AddGroup_Click"
                                CornerRadius="{StaticResource CueRadiusSmall}"
                                AutomationProperties.Name="새 그룹"
                                ToolTipService.ToolTip="새 그룹">
                                <FontIcon FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE710;" />
                            </Button>
                        </Grid>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
                <!-- Divides the group block from the tag block. Hidden in the compact pane, where a
                     separator between icon-only rows reads as noise — see UpdateNavRowInsets. -->
                <NavigationViewItemSeparator x:Name="GroupTagSeparator" Margin="0,4,0,4" />
                <NavigationViewItem
                    x:Name="TagsSection"
                    HorizontalContentAlignment="Stretch"
                    IsExpanded="True"
                    SelectsOnInvoked="False">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8EC;" />
                    </NavigationViewItem.Icon>
                    <NavigationViewItem.Content>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock
                                VerticalAlignment="Center"
                                FontFamily="{StaticResource CueFontFamilySemiBold}"
                                FontSize="12"
                                Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                                Text="태그" />
                            <Button
                                Grid.Column="1"
                                Width="26"
                                Height="26"
                                Margin="0,0,4,0"
                                Padding="0"
                                Background="Transparent"
                                BorderThickness="0"
                                Click="AddTag_Click"
                                CornerRadius="{StaticResource CueRadiusSmall}"
                                AutomationProperties.Name="새 태그"
                                ToolTipService.ToolTip="새 태그">
                                <FontIcon FontSize="15" Foreground="{ThemeResource TextFillColorSecondaryBrush}" Glyph="&#xE710;" />
                            </Button>
                        </Grid>
                    </NavigationViewItem.Content>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <NavigationView.FooterMenuItems>
                <!-- SPIKE (Step 0, throwaway): remove this item with ImeSpikePage and the "imespike" nav branch. -->
                <NavigationViewItem x:Name="ImeSpikeItem" Content="IME 스파이크" Tag="imespike">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE90F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem x:Name="SettingsItem" Content="설정" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>
            <Frame x:Name="NavFrame" />
        </NavigationView>

        <!-- Bottom snackbars. All three carry the same floating-card properties (8px card radius, max
             width, fixed bottom-right placement) — set per instance rather than via a shared Style, since
             the default InfoBar style key isn't present on every WinUI version and a no-BasedOn Style would
             strip the template — so autosave progress, save failure, and the off-screen quick-add notice
             read as one calm WinUI surface. -->
        <InfoBar
            x:Name="GlobalSavingInfoBar"
            Grid.Row="1"
            CornerRadius="{StaticResource CueRadiusCard}"
            MaxWidth="{StaticResource CueSnackbarMaxWidth}"
            Margin="{StaticResource CuePadPage}"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Right"
            IsOpen="False"
            Severity="Informational"
            Message="변경 사항을 저장하고 있습니다…"
            IsClosable="False"
            Canvas.ZIndex="999" />

        <InfoBar
            x:Name="GlobalErrorInfoBar"
            Grid.Row="1"
            CornerRadius="{StaticResource CueRadiusCard}"
            MaxWidth="{StaticResource CueSnackbarMaxWidth}"
            Margin="{StaticResource CuePadPage}"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Right"
            IsOpen="False"
            Severity="Informational"
            Title="저장 실패"
            Message="저장하지 못한 할 일이 있습니다"
            IsClosable="True"
            CloseButtonClick="GlobalErrorInfoBar_CloseButtonClick"
            Canvas.ZIndex="999">
            <!-- 다시 시도 is the inline primary (the clean WinUI ActionButton slot); 지금 종료 is the quiet
                 secondary escape hatch, shown only during the close flow. -->
            <InfoBar.ActionButton>
                <Button x:Name="RetryButton" Content="다시 시도" Click="RetryButton_Click" Style="{ThemeResource AccentButtonStyle}" />
            </InfoBar.ActionButton>
            <InfoBar.Content>
                <Button
                    x:Name="ForceExitButton"
                    Margin="0,0,0,12"
                    Click="ForceExitButton_Click"
                    Content="지금 종료"
                    Style="{StaticResource CueSubtleTextButtonStyle}"
                    Visibility="Collapsed" />
            </InfoBar.Content>
        </InfoBar>

        <!-- A quick-add that lands a task on a day the current screen doesn't show (e.g. "내일 …" typed on
             오늘 할 일) is easy to lose track of, so this snackbar confirms it was created and offers a jump
             to 모든 할 일, where every active task is visible. Auto-dismisses after a few seconds (see
             ShowOffscreenTaskSnackbar). -->
        <InfoBar
            x:Name="OffscreenTaskInfoBar"
            Grid.Row="1"
            CornerRadius="{StaticResource CueRadiusCard}"
            MaxWidth="{StaticResource CueSnackbarMaxWidth}"
            Margin="{StaticResource CuePadPage}"
            VerticalAlignment="Bottom"
            HorizontalAlignment="Right"
            IsOpen="False"
            Severity="Informational"
            Message="오늘이 아닌 다른 날의 할 일이 만들어졌어요."
            IsClosable="True"
            Canvas.ZIndex="999">
            <InfoBar.ActionButton>
                <Button Content="모든 할 일로 이동" Click="OffscreenGoAllTasks_Click" />
            </InfoBar.ActionButton>
        </InfoBar>
    </Grid>
</Window>
